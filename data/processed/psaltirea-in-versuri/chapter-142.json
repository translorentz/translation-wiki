{
  "title": "Psalmul 150 (Psalm 150)",
  "paragraphs": [
    {
      "index": 0,
      "text": "Lăudațî-l cu tot omul"
    },
    {
      "index": 1,
      "text": "Întru svinții săi pre Domnul, Lăudațî-l în vârtute"
    },
    {
      "index": 2,
      "text": "Ce-are Domnul de oști multe. Lăudaț fără tăcere"
    },
    {
      "index": 3,
      "text": "De-a lui sâlă și putere, Lăudațî-l în mărire"
    },
    {
      "index": 4,
      "text": "De-a lui multă biruire. Lăudaț cu glasuri nalte"
    },
    {
      "index": 5,
      "text": "De bucine ferecate, Lăudațî-l în lăute,"
    },
    {
      "index": 6,
      "text": "În psăltiri pre viersuri multe. Lăudaț pre toate locuri"
    },
    {
      "index": 7,
      "text": "’"
    },
    {
      "index": 8,
      "text": "Cu tâmpene și cu giocuri, Lăudațî-l să răsune"
    },
    {
      "index": 9,
      "text": "În organe tinse-n strune. Lăudaț cu bune viersuri"
    },
    {
      "index": 10,
      "text": "De chimvale într-alesuri, Lăudaț și-l strigaț tare"
    },
    {
      "index": 11,
      "text": "În țimbale de cântare. Câte-s vie și tot omul,"
    },
    {
      "index": 12,
      "text": "Lăudațî-l toț pre Domnul."
    },
    {
      "index": 13,
      "text": "[STIHURI DESPRE ORIGINEA LATINĂ A ROMÂNILOR]"
    },
    {
      "index": 14,
      "text": "Neamul Țării Moldovei de unde dă rază?"
    },
    {
      "index": 15,
      "text": "Din țara Italíei, tot omul să crează."
    },
    {
      "index": 16,
      "text": "Fliah întăi, apoi Traian au adus pre-acice"
    },
    {
      "index": 17,
      "text": "Pre strămoșii cestor țări de neam cu ferice. Răsădit-au țărilor hotarele toate"
    },
    {
      "index": 18,
      "text": "Pre semne ce stau în veci a să vedea poate. El cu vița cestui neam Țara Rumânească"
    },
    {
      "index": 19,
      "text": "Împlut-au, Ardealul tot și Moldovenească. Semnele stau de să văd de dânsul făcute,"
    },
    {
      "index": 20,
      "text": "Turnul Severinului să custe-n vremi multe. Strămoșii Moldoveei adus-au în țară,"
    },
    {
      "index": 21,
      "text": "Pre ghețâi cu sabia scoțând din hotară. Stau semnele podului cu praguri căzute"
    },
    {
      "index": 22,
      "text": "Și Turnul Severinului, de Sevír făcute. Podul preste Dunăre-n Țara Rumânească,"
    },
    {
      "index": 23,
      "text": "De-au trecutu-ș oștile-n Țara Ungurească. Pre-acela pod au trecut Moldoavei strămoșii,"
    },
    {
      "index": 24,
      "text": "Bătând război cu dachii, a sasilor moșii."
    },
    {
      "index": 25,
      "text": "APOSTROF"
    },
    {
      "index": 26,
      "text": "Cine-i bogat de-avere pre lume-n tot omul,"
    },
    {
      "index": 27,
      "text": "De nu v-avea-ntru sine lăcuind pre Domnul, Acela de-avuțâie sațâu nu mai vede,"
    },
    {
      "index": 28,
      "text": "De i-ar da toată lumea, el tot nu să-ncrede. Și de cât mai mult strânge, mai mult să lărgește,"
    },
    {
      "index": 29,
      "text": "Și tot deșert să vede-ntr-averea ce-i crește. Deci nime-ntr-avere să nu să gândească"
    },
    {
      "index": 30,
      "text": "Că va putea să să-mple, să să odihnească. Iară-ntr-a cărui suflet Domnul lăcuiește,"
    },
    {
      "index": 31,
      "text": "Acela de nemică nu mai jeluiește. Pentr-aceea tot omul să nu să lenească"
    },
    {
      "index": 32,
      "text": "Pre Dumnezău în suflet să-ș agonisască."
    },
    {
      "index": 33,
      "text": "Din Paraclisul Preacuratei Născătoare de Dumnezeu"
    },
    {
      "index": 34,
      "text": "I"
    },
    {
      "index": 35,
      "text": "De trupești neputințe"
    },
    {
      "index": 36,
      "text": "Și de sufletești boale,"
    },
    {
      "index": 37,
      "text": "A lui Dumnezău Maică,"
    },
    {
      "index": 38,
      "text": "Pre carii vin cu dorul"
    },
    {
      "index": 39,
      "text": "Supt umbra ta cea svântă,"
    },
    {
      "index": 40,
      "text": "Spodobește-le leacul,"
    },
    {
      "index": 41,
      "text": "Care-ai născut pre Hristos,"
    },
    {
      "index": 42,
      "text": "Mântuitoriul nostru."
    },
    {
      "index": 43,
      "text": "II"
    },
    {
      "index": 44,
      "text": "Năpăști ce-m fac năvală"
    },
    {
      "index": 45,
      "text": "Svinția-ta le-mpraștii"
    },
    {
      "index": 46,
      "text": "Și patimi ce-m vin gloată"
    },
    {
      "index": 47,
      "text": "De m-asupresc, Ficioară."
    },
    {
      "index": 48,
      "text": "Pentr-aceea te cântăm"
    },
    {
      "index": 49,
      "text": "Cu laudă-n toț vecii."
    },
    {
      "index": 50,
      "text": "III"
    },
    {
      "index": 51,
      "text": "Liniște fii și dvorbă"
    },
    {
      "index": 52,
      "text": "Acelora ce scapă"
    },
    {
      "index": 53,
      "text": "Cătră tine, Ficioară,"
    },
    {
      "index": 54,
      "text": "Și părete-n primejde,"
    },
    {
      "index": 55,
      "text": "Năzuință și umbră"
    },
    {
      "index": 56,
      "text": "Le fii, și bucurie."
    },
    {
      "index": 57,
      "text": "IV"
    },
    {
      "index": 58,
      "text": "Dintr-a ta strălucoare"
    },
    {
      "index": 59,
      "text": "Luminează, Ficioară,"
    },
    {
      "index": 60,
      "text": "Negura neputinții,"
    },
    {
      "index": 61,
      "text": "Să fugă de la ceia"
    },
    {
      "index": 62,
      "text": "Ce cu bună credință,"
    },
    {
      "index": 63,
      "text": "A lui Dumnezău Maică,"
    },
    {
      "index": 64,
      "text": "Te spun cu mărturie."
    },
    {
      "index": 65,
      "text": "V"
    },
    {
      "index": 66,
      "text": "La loc de răutate,"
    },
    {
      "index": 67,
      "text": "Plecat în neputință,"
    },
    {
      "index": 68,
      "text": "Svinția-ta, Ficioară,"
    },
    {
      "index": 69,
      "text": "Să-m trimiț sănătate,"
    },
    {
      "index": 70,
      "text": "Schimbându-mă din boală."
    },
    {
      "index": 71,
      "text": "VI"
    },
    {
      "index": 72,
      "text": "O, prealuminat núor,"
    },
    {
      "index": 73,
      "text": "A lui Dumnezău Maică,"
    },
    {
      "index": 74,
      "text": "Pre ceia ce ne luptă"
    },
    {
      "index": 75,
      "text": "Le dă durere multă,"
    },
    {
      "index": 76,
      "text": "Cu svânta ta direaptă"
    },
    {
      "index": 77,
      "text": "Vestită de putere."
    },
    {
      "index": 78,
      "text": "Pre cei din grele scârbe"
    },
    {
      "index": 79,
      "text": "Le fii, Ficioară, dvorbă,"
    },
    {
      "index": 80,
      "text": "Pre cei din strâmbătate"
    },
    {
      "index": 81,
      "text": "Îi apără și-i scoate."
    },
    {
      "index": 82,
      "text": "Dezleagă-i din greșele"
    },
    {
      "index": 83,
      "text": "Pre carii țî să roagă,"
    },
    {
      "index": 84,
      "text": "Că svinția-ta, Doamnă,"
    },
    {
      "index": 85,
      "text": "Câte vei țî să poate."
    },
    {
      "index": 86,
      "text": "VII"
    },
    {
      "index": 87,
      "text": "Cade-să-ntr-adevărul"
    },
    {
      "index": 88,
      "text": "Toț să te fericească,"
    },
    {
      "index": 89,
      "text": "A lui Dumnezău Maică,"
    },
    {
      "index": 90,
      "text": "Pururea fericită"
    },
    {
      "index": 91,
      "text": "Și-n tot fără prihană,"
    },
    {
      "index": 92,
      "text": "Dumnezăului nostru"
    },
    {
      "index": 93,
      "text": "Ce ești Maică cinstită,"
    },
    {
      "index": 94,
      "text": "Mai sus de heruvimii"
    },
    {
      "index": 95,
      "text": "Și decât serafimii"
    },
    {
      "index": 96,
      "text": "Fără samă slăvită."
    },
    {
      "index": 97,
      "text": "Fără de putregiune"
    },
    {
      "index": 98,
      "text": "Pre Dumnezău cuvântul."
    },
    {
      "index": 99,
      "text": "Doamnă, ce l-ai născutu-l,"
    },
    {
      "index": 100,
      "text": "Că ești adevărată"
    },
    {
      "index": 101,
      "text": "A lui Dumnezău Maică,"
    },
    {
      "index": 102,
      "text": "De te mărim, Ficioară."
    },
    {
      "index": 103,
      "text": "VIII"
    },
    {
      "index": 104,
      "text": "Tuturor ești de dvorbă,"
    },
    {
      "index": 105,
      "text": "Dintr-a ta bunătate,"
    },
    {
      "index": 106,
      "text": "Cărór scapă-n credință"
    },
    {
      "index": 107,
      "text": "La svânta ta umbreală,"
    },
    {
      "index": 108,
      "text": "Că pre alt nime n-ávem"
    },
    {
      "index": 109,
      "text": "La Dumnezău, greșițâi."
    },
    {
      "index": 110,
      "text": "La nevoi și la scârbe"
    },
    {
      "index": 111,
      "text": "Pururea izbăvință."
    },
    {
      "index": 112,
      "text": "Sărcinaț de păcate,"
    },
    {
      "index": 113,
      "text": "Blagoslovită Maică"
    },
    {
      "index": 114,
      "text": "Domnului din nălțâme,"
    },
    {
      "index": 115,
      "text": "Cădem cu rugăminte,"
    },
    {
      "index": 116,
      "text": "De la toată năvala"
    },
    {
      "index": 117,
      "text": "Svinția-ta ne scoate"
    },
    {
      "index": 118,
      "text": "Pre șerbii tăi, Ficioară."
    },
    {
      "index": 119,
      "text": "IX"
    },
    {
      "index": 120,
      "text": "Tuturor ce-s în scârbă"
    },
    {
      "index": 121,
      "text": "Le ești de bucurie,"
    },
    {
      "index": 122,
      "text": "Celor cu asupreală"
    },
    {
      "index": 123,
      "text": "Le ești de sprejineală,"
    },
    {
      "index": 124,
      "text": "Flămânzâlor ești hrană,"
    },
    {
      "index": 125,
      "text": "Streinilor scutință,"
    },
    {
      "index": 126,
      "text": "Celora ce-s în valuri"
    },
    {
      "index": 127,
      "text": "Le ești adăposteală,"
    },
    {
      "index": 128,
      "text": "Celora ce-s în boale"
    },
    {
      "index": 129,
      "text": "Le ești de socotință,"
    },
    {
      "index": 130,
      "text": "Celor cu neputințe"
    },
    {
      "index": 131,
      "text": "Umbră și sprejineală,"
    },
    {
      "index": 132,
      "text": "Toiag de bătrânețe."
    },
    {
      "index": 133,
      "text": "A lui Dumnezău Maică"
    },
    {
      "index": 134,
      "text": "Celui de Sus curată,"
    },
    {
      "index": 135,
      "text": "Ne rugăm sârguiește"
    },
    {
      "index": 136,
      "text": "Serbii tăi de ne scoate."
    }
  ]
}