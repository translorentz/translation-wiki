{
  "title": "Psalmul 100 (Psalm 100)",
  "paragraphs": [
    {
      "index": 0,
      "text": "De mila ta,"
    },
    {
      "index": 1,
      "text": "Doamne svinte,"
    },
    {
      "index": 2,
      "text": "Și de giudeț țâind minte,"
    },
    {
      "index": 3,
      "text": "Voi cânta ș-oi înțălege Fără vină ce voi merge"
    },
    {
      "index": 4,
      "text": "Pre cale-ntr-această viață,"
    },
    {
      "index": 5,
      "text": "Ca să-m vii fără de greață, Când petrec fără de vină"
    },
    {
      "index": 6,
      "text": "Și cu inemă senină"
    },
    {
      "index": 7,
      "text": "În mijlocul casii mele,"
    },
    {
      "index": 8,
      "text": "Ferindu-mă de smintele."
    },
    {
      "index": 9,
      "text": "N-am suferit strâmbătate Să văz nice de departe."
    },
    {
      "index": 10,
      "text": "Ceia ce-ș ies din tocmală I-am urât ca o sminteală."
    },
    {
      "index": 11,
      "text": "Nu s-au dat cu mine-n viață Cel cu inemă sămață, Și cu cel fără credință Nu mi-am făcut cunoștință."
    },
    {
      "index": 12,
      "text": "Și l-am scosu-l cu ocară Pre clevetnicul afară."
    },
    {
      "index": 13,
      "text": "Cel cu căutătura mândră Nu l-am avutu-l în sâmbră, Nice-am suferit în casă Lacomul să-l pui la masă."
    },
    {
      "index": 14,
      "text": "Ce-am căutat cu față lină Cătră cel fără de vină, De l-am chematu-l în casă Să-l văz cu mine la masă."
    },
    {
      "index": 15,
      "text": "Și cel cu răbdare lungă L-am priimit să-m fie slugă, Ce să ferește de vină, Ca să-ș facă slujba plină."
    },
    {
      "index": 16,
      "text": "În casa mea n-au fost harnic Să petreacă omul falnic, Nice-am lăsat mincinosulSă strice cúiva folosul."
    },
    {
      "index": 17,
      "text": "Și de strâmbii mi-au fost greață Să-i văz demineață-n față."
    },
    {
      "index": 18,
      "text": "Ce i-am ucisu-i din țară Pre toț răii cu ocară, Să-i concenesc din cetate Pre toț ce fac răutate."
    },
    {
      "index": 19,
      "text": "Doamne, mi-ascultă de rugă"
    },
    {
      "index": 20,
      "text": "Ce mă rog din vreme lungă,"
    },
    {
      "index": 21,
      "text": "Și strigarea mea să margă"
    },
    {
      "index": 22,
      "text": "Spre tine, să să-nțăleagă."
    },
    {
      "index": 23,
      "text": "Nu-ț întoarce svânta față"
    },
    {
      "index": 24,
      "text": "De cătră mine cu greață."
    },
    {
      "index": 25,
      "text": "Și la zî ce sunt cu jele"
    },
    {
      "index": 26,
      "text": "Și cu tângă de greșele,"
    },
    {
      "index": 27,
      "text": "Pleacă-ț auzul spre mine"
    },
    {
      "index": 28,
      "text": "Și să-m hii, Doamne, cu bine."
    },
    {
      "index": 29,
      "text": "Și la ce zî ti-oi striga-te,"
    },
    {
      "index": 30,
      "text": "Să mi-auz de greutate,"
    },
    {
      "index": 31,
      "text": "Că-m trec zâlele ca fumul,"
    },
    {
      "index": 32,
      "text": "Oasele mi-s săci ca scrumul."
    },
    {
      "index": 33,
      "text": "Ca nește iarbă tăiată"
    },
    {
      "index": 34,
      "text": "M-este inema săcată,"
    },
    {
      "index": 35,
      "text": "Că stă uitată de mine,"
    },
    {
      "index": 36,
      "text": "Ce-am cătat să mănânc pâine."
    },
    {
      "index": 37,
      "text": "De suspinuri și de jele"
    },
    {
      "index": 38,
      "text": "Mi-am lipitu-mi os de piele."
    },
    {
      "index": 39,
      "text": "De-atocma cu pelecanul,"
    },
    {
      "index": 40,
      "text": "Prin pustii petrec tot anul,"
    },
    {
      "index": 41,
      "text": "Și ca corbul cel de noapte"
    },
    {
      "index": 42,
      "text": "Îm petrec zâlele toate,"
    },
    {
      "index": 43,
      "text": "Ca o vrabie rămasă"
    },
    {
      "index": 44,
      "text": "În supt streșină de casă."
    },
    {
      "index": 45,
      "text": "Toată zua mi să strâmbă"
    },
    {
      "index": 46,
      "text": "Pizmașii miei, de-m fac scârbă,"
    },
    {
      "index": 47,
      "text": "Și ceia ce mă-mbunează"
    },
    {
      "index": 48,
      "text": "Fac giurământ să mă piarză."
    },
    {
      "index": 49,
      "text": "Am mâncat pâine de zgură"
    },
    {
      "index": 50,
      "text": "Și lacrămi în băutură,"
    },
    {
      "index": 51,
      "text": "De fața mâniii tale,"
    },
    {
      "index": 52,
      "text": "Ce mi-ai dat de sus la vale."
    },
    {
      "index": 53,
      "text": "Mi-s zâlele trecătoare,"
    },
    {
      "index": 54,
      "text": "De fug ca umbra de soare,"
    },
    {
      "index": 55,
      "text": "Și ca iarba cea tăiată"
    },
    {
      "index": 56,
      "text": "Mi-este vârtutea săcată."
    },
    {
      "index": 57,
      "text": "Iară tu, Dumnezău svinte,"
    },
    {
      "index": 58,
      "text": "Tot ești din veci, de mainte,"
    },
    {
      "index": 59,
      "text": "Și petreci în rod de rudă,"
    },
    {
      "index": 60,
      "text": "Tu te scoală fără trudă"
    },
    {
      "index": 61,
      "text": "De vei milui Sionul,"
    },
    {
      "index": 62,
      "text": "Și să-l cruț, că tu-i ești Domnul."
    },
    {
      "index": 63,
      "text": "Că-i sunt vremile venite"
    },
    {
      "index": 64,
      "text": "Și pietrile îndrăgite"
    },
    {
      "index": 65,
      "text": "De șerbii svințiii-tale,"
    },
    {
      "index": 66,
      "text": "Și țărna cea de pre cale."
    },
    {
      "index": 67,
      "text": "Și ț-vor cinsti svântul nume"
    },
    {
      "index": 68,
      "text": "Limbile toate din lume,"
    },
    {
      "index": 69,
      "text": "Și cu dragoste toț craii"
    },
    {
      "index": 70,
      "text": "Ț-vor vedea slava cu aii."
    },
    {
      "index": 71,
      "text": "Că vei zidi, Doamne svinte,"
    },
    {
      "index": 72,
      "text": "Sionul ca de mainte"
    },
    {
      "index": 73,
      "text": "Și ț-vei ivi svânta față"
    },
    {
      "index": 74,
      "text": "Cu slavă și cu dulceață."
    },
    {
      "index": 75,
      "text": "Că le vei căuta de rugă"
    },
    {
      "index": 76,
      "text": "Celor din pedeapsă lungă,"
    },
    {
      "index": 77,
      "text": "Și de dânș nu-ț va fi greață,"
    },
    {
      "index": 78,
      "text": "Ce să roagă cu dulceață."
    },
    {
      "index": 79,
      "text": "Și aceasta să să scrie"
    },
    {
      "index": 80,
      "text": "Preste alt rod ce-a să vie."
    },
    {
      "index": 81,
      "text": "Și oameni ce s-or zidi-să"
    },
    {
      "index": 82,
      "text": "Ti-or cânta cu voaie tinsă,"
    },
    {
      "index": 83,
      "text": "Că ț-ai căutat spre mulțâme"
    },
    {
      "index": 84,
      "text": "De la svânta ta nălțâme."
    },
    {
      "index": 85,
      "text": "Și Domnul din ceri, dând rază,"
    },
    {
      "index": 86,
      "text": "Căută spre pământ să vază"
    },
    {
      "index": 87,
      "text": "Și s-auză de durere"
    },
    {
      "index": 88,
      "text": "Celor ferecaț în here,"
    },
    {
      "index": 89,
      "text": "Și cei uciș fără lege"
    },
    {
      "index": 90,
      "text": "Cuconii să le dezlege."
    },
    {
      "index": 91,
      "text": "Să dea vestea-n tot Sionul"
    },
    {
      "index": 92,
      "text": "De bine ce-au făcut Domnul,"
    },
    {
      "index": 93,
      "text": "Să-i laude svântul nume,"
    },
    {
      "index": 94,
      "text": "În Ierusalim și-n lume,"
    },
    {
      "index": 95,
      "text": "Și gloatele cu grămadă"
    },
    {
      "index": 96,
      "text": "Să să strângă la făgadă."
    },
    {
      "index": 97,
      "text": "Și-mpărațâi cu tot omul"
    },
    {
      "index": 98,
      "text": "Să slujască toț la Domnul,"
    },
    {
      "index": 99,
      "text": "Și să-i răspunză-n tărie"
    },
    {
      "index": 100,
      "text": "Cu cale de mărturie."
    },
    {
      "index": 101,
      "text": "Să-m dai veste și cu bine"
    },
    {
      "index": 102,
      "text": "Pentru zâle ce-am puțâne,"
    },
    {
      "index": 103,
      "text": "Și când îm vei lua viața,"
    },
    {
      "index": 104,
      "text": "Mă rog, Doamne, să-ț văz fața."
    },
    {
      "index": 105,
      "text": "Că preste tot rod de rudă"
    },
    {
      "index": 106,
      "text": "Îț sunt aii fără trudă."
    },
    {
      "index": 107,
      "text": "Și tu, Doamne, cu cuvântul"
    },
    {
      "index": 108,
      "text": "Dintăi ai urzât pământul,"
    },
    {
      "index": 109,
      "text": "Și ceriurile ce-s nalte"
    },
    {
      "index": 110,
      "text": "Sunt de mâna ta lucrate."
    },
    {
      "index": 111,
      "text": "Acelea toate s-or trece,"
    },
    {
      "index": 112,
      "text": "Iară tu tot vei petrece."
    },
    {
      "index": 113,
      "text": "Și ca haina ponosâtă,"
    },
    {
      "index": 114,
      "text": "Când le-a hi vremea sosâtă,"
    },
    {
      "index": 115,
      "text": "Li s-a destrăma făptura"
    },
    {
      "index": 116,
      "text": "Din hire, ca vechitura."
    },
    {
      "index": 117,
      "text": "Și li-i depăna ca tortul,"
    },
    {
      "index": 118,
      "text": "De să vor schimba cu totul."
    },
    {
      "index": 119,
      "text": "Iară tu, Dumnezău svinte,"
    },
    {
      "index": 120,
      "text": "Tot ești Domn, ca și mainte,"
    },
    {
      "index": 121,
      "text": "Și trăiești pre așezare"
    },
    {
      "index": 122,
      "text": "Ca cela ce ești Domn tare."
    },
    {
      "index": 123,
      "text": "Și fiii slugilor tale"
    },
    {
      "index": 124,
      "text": "Le vei deșchide-le cale,"
    },
    {
      "index": 125,
      "text": "Să-ș descalece moșie,"
    },
    {
      "index": 126,
      "text": "Să s-așeze cu vecie"
    },
    {
      "index": 127,
      "text": "Și să-ș rădice sămânță,"
    },
    {
      "index": 128,
      "text": "Să-ț slujască cu credință."
    }
  ]
}