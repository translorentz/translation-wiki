{
  "title": "Psalmul 48 (Psalm 48)",
  "paragraphs": [
    {
      "index": 0,
      "text": "Ascultaț acestea, toate"
    },
    {
      "index": 1,
      "text": "Năroade, neamuri și gloate,"
    },
    {
      "index": 2,
      "text": "Să-mi înțăleagă cuvântul"
    },
    {
      "index": 3,
      "text": "Omul de pre tot pământul,"
    },
    {
      "index": 4,
      "text": "Bogătașii depreună"
    },
    {
      "index": 5,
      "text": "Cu mișeii când s-adună,"
    },
    {
      "index": 6,
      "text": "Să vă spui de-nțălepciune"
    },
    {
      "index": 7,
      "text": "Cu-nțăles de-nvățuri bune."
    },
    {
      "index": 8,
      "text": "Și auzul să vă tindeț,"
    },
    {
      "index": 9,
      "text": "Pildele să le deprindeț,"
    },
    {
      "index": 10,
      "text": "S-ascultaț fără de price,"
    },
    {
      "index": 11,
      "text": "Să-nțălegeț ce voi zâce."
    },
    {
      "index": 12,
      "text": "Să te temi de zî cumplită,"
    },
    {
      "index": 13,
      "text": "Să nu-ț dea de călcăi smântă."
    },
    {
      "index": 14,
      "text": "Cela ce ai bogățâie,"
    },
    {
      "index": 15,
      "text": "Să nu stai în sămețâie,"
    },
    {
      "index": 16,
      "text": "Nice s-aibi nedejde-n frate."
    },
    {
      "index": 17,
      "text": "Sau în om, la greutate."
    },
    {
      "index": 18,
      "text": "Și cu ce schimb va da omul,"
    },
    {
      "index": 19,
      "text": "Să să schimbe de la Domnul?"
    },
    {
      "index": 20,
      "text": "Cu preț de răscumpărare"
    },
    {
      "index": 21,
      "text": "Sufletului, de pierzare?"
    },
    {
      "index": 22,
      "text": "Fi-i-va truda nencetată,"
    },
    {
      "index": 23,
      "text": "Că la iad nu va fi plată."
    },
    {
      "index": 24,
      "text": "Acolo n-a vedea moarte,"
    },
    {
      "index": 25,
      "text": "Să gândească că-l va scoate."
    },
    {
      "index": 26,
      "text": "Că măiestrul încă moare,"
    },
    {
      "index": 27,
      "text": "Ca tot omul de supt soare."
    },
    {
      "index": 28,
      "text": "Și nebunul cu buiacul"
    },
    {
      "index": 29,
      "text": "Vor pieri de pre tot veacul."
    },
    {
      "index": 30,
      "text": "Ș-averea de dânș rămâne"
    },
    {
      "index": 31,
      "text": "De o iau rude streine."
    },
    {
      "index": 32,
      "text": "Cât să vor scoate din casă,"
    },
    {
      "index": 33,
      "text": "Numele li s-a uita-să,"
    },
    {
      "index": 34,
      "text": "Li s-a uita și mormântul,"
    },
    {
      "index": 35,
      "text": "Cât i-a-mpresura pământul,"
    },
    {
      "index": 36,
      "text": "Ceia ce nu-ș fac pre lume"
    },
    {
      "index": 37,
      "text": "De bunătăț s-aibă nume."
    },
    {
      "index": 38,
      "text": "Ce folos este de cinste"
    },
    {
      "index": 39,
      "text": "Omului fără de minte,"
    },
    {
      "index": 40,
      "text": "Ce-ș dă firea omenească"
    },
    {
      "index": 41,
      "text": "Pre fire dobitocească,"
    },
    {
      "index": 42,
      "text": "De merge fără sâială"
    },
    {
      "index": 43,
      "text": "Pre calea cea de sminteală?"
    },
    {
      "index": 44,
      "text": "Nu cunoaște că-l va duce"
    },
    {
      "index": 45,
      "text": "Dezmierdăciunea cea dulce"
    },
    {
      "index": 46,
      "text": "De va da ca oaia-n râpă,"
    },
    {
      "index": 47,
      "text": "Și moartea l-va sorbi-n pripă."
    },
    {
      "index": 48,
      "text": "Iară direpțâi, dând rază,"
    },
    {
      "index": 49,
      "text": "Vor prăvi cum duc să piarză"
    },
    {
      "index": 50,
      "text": "Pre păcătos și buiacul,"
    },
    {
      "index": 51,
      "text": "Să-ș petreacă-n iad tot veacul."
    },
    {
      "index": 52,
      "text": "De la slavă să să rază"
    },
    {
      "index": 53,
      "text": "Și cinstea toată să-ș piarză."
    },
    {
      "index": 54,
      "text": "Ce mă rog, Dumnezău svinte,"
    },
    {
      "index": 55,
      "text": "Să-m iei sufletul aminte"
    },
    {
      "index": 56,
      "text": "Și să mă cuprinz cu milă,"
    },
    {
      "index": 57,
      "text": "Să nu-m facă răul sâlă."
    },
    {
      "index": 58,
      "text": "Iară tu, oame mișele,"
    },
    {
      "index": 59,
      "text": "Să nu dai de gânduri rele,"
    },
    {
      "index": 60,
      "text": "Când vez pre păgân că crește"
    },
    {
      "index": 61,
      "text": "Și casa lui să lățește."
    },
    {
      "index": 62,
      "text": "Că deaca moare, el piere,"
    },
    {
      "index": 63,
      "text": "Cu slava lui, cu avere."
    },
    {
      "index": 64,
      "text": "Cu dâns nemică nu duce"
    },
    {
      "index": 65,
      "text": "Dintr-averea lui cea dulce."
    },
    {
      "index": 66,
      "text": "Că-ntr-această lume-n viață"
    },
    {
      "index": 67,
      "text": "I-i sufletul în dulceață."
    },
    {
      "index": 68,
      "text": "Și cine i să-mbunează,"
    },
    {
      "index": 69,
      "text": "I-i drag pre-acela să-l vază."
    },
    {
      "index": 70,
      "text": "Cine-i spune-n dereptate."
    },
    {
      "index": 71,
      "text": "De-acela fuge departe,"
    },
    {
      "index": 72,
      "text": "Că-i deprins pre cale largă"
    },
    {
      "index": 73,
      "text": "Cătră pierire de-aleargă"
    },
    {
      "index": 74,
      "text": "Și să trage pre moșie"
    },
    {
      "index": 75,
      "text": "La-ntunerec de vecie."
    },
    {
      "index": 76,
      "text": "Ce folos este de cinste"
    },
    {
      "index": 77,
      "text": "Omului fără de minte."
    },
    {
      "index": 78,
      "text": "Ce-ș dă hirea omenească"
    },
    {
      "index": 79,
      "text": "Pre hire dobitocească ?"
    }
  ]
}