{
  "title": "Psalmul 46 (Psalm 46)",
  "paragraphs": [
    {
      "index": 0,
      "text": "Limbile să salte"
    },
    {
      "index": 1,
      "text": "Cu cântece nalte,"
    },
    {
      "index": 2,
      "text": "Să strige-n tărie"
    },
    {
      "index": 3,
      "text": "Glas de bucurie,"
    },
    {
      "index": 4,
      "text": "Lăudând pre Domnul,"
    },
    {
      "index": 5,
      "text": "Să cânte tot omul."
    },
    {
      "index": 6,
      "text": "Domnul este tare,"
    },
    {
      "index": 7,
      "text": "Este-mpărat mare"
    },
    {
      "index": 8,
      "text": "Preste tot pământul"
    },
    {
      "index": 9,
      "text": "Și-ș țâne cuvântul."
    },
    {
      "index": 10,
      "text": "Supusu-ne-au gloate"
    },
    {
      "index": 11,
      "text": "Și limbile toate,"
    },
    {
      "index": 12,
      "text": "De ni-s supt picioare"
    },
    {
      "index": 13,
      "text": "Limbi de pre supt soare."
    },
    {
      "index": 14,
      "text": "Alesu-ș-au șie"
    },
    {
      "index": 15,
      "text": "Parte de moșie"
    },
    {
      "index": 16,
      "text": "Țara cea dorită."
    },
    {
      "index": 17,
      "text": "Carea-i giuruită"
    },
    {
      "index": 18,
      "text": "Lui Iacov iubitul,"
    },
    {
      "index": 19,
      "text": "Ce-i țâne cuvântul,"
    },
    {
      "index": 20,
      "text": "Mila să-ș arate"
    },
    {
      "index": 21,
      "text": "Cea de bunătate"
    },
    {
      "index": 22,
      "text": "Spre noi, ticăloșii,"
    },
    {
      "index": 23,
      "text": "Precum ne spun moșii."
    },
    {
      "index": 24,
      "text": "Pre vârvuri de munte"
    },
    {
      "index": 25,
      "text": "S-aud glasuri multe"
    },
    {
      "index": 26,
      "text": "De bucine mare,"
    },
    {
      "index": 27,
      "text": "Cu naltă strigare,"
    },
    {
      "index": 28,
      "text": "Că s-au suit"
    },
    {
      "index": 29,
      "text": "Domnul Să-l vază tot omul."
    },
    {
      "index": 30,
      "text": "Cântaț în lăute,"
    },
    {
      "index": 31,
      "text": "În zâcături multe,"
    },
    {
      "index": 32,
      "text": "Cântaț pre-mpăratul,"
    },
    {
      "index": 33,
      "text": "Că nu-i ca dâns altul"
    },
    {
      "index": 34,
      "text": "Să domnească-n lume,"
    },
    {
      "index": 35,
      "text": "Cu svântul său nume,"
    },
    {
      "index": 36,
      "text": "Cântaț să-nțăleagă"
    },
    {
      "index": 37,
      "text": "Preste lume largă."
    },
    {
      "index": 38,
      "text": "Că Dumnezău poate"
    },
    {
      "index": 39,
      "text": "Pre limbi preste toate,"
    },
    {
      "index": 40,
      "text": "De le îmblânzește"
    },
    {
      "index": 41,
      "text": "Și le-mpărățește."
    },
    {
      "index": 42,
      "text": "Scaunul dă rază"
    },
    {
      "index": 43,
      "text": "Unde va să șază"
    },
    {
      "index": 44,
      "text": "Domnul din direapta,"
    },
    {
      "index": 45,
      "text": "Să-mpărțască plata,"
    },
    {
      "index": 46,
      "text": "Pre boieri, pre gloate,"
    },
    {
      "index": 47,
      "text": "Pre limbile toate."
    },
    {
      "index": 48,
      "text": "Și cine să-nalță"
    },
    {
      "index": 49,
      "text": "Din hire sămață,"
    },
    {
      "index": 50,
      "text": "I-a vedea tot omul"
    },
    {
      "index": 51,
      "text": "Cum i-a certa Domnul."
    }
  ]
}