{
  "title": "Psalmul 53 (Psalm 53)",
  "paragraphs": [
    {
      "index": 0,
      "text": "Doamne, mă spăsește"
    },
    {
      "index": 1,
      "text": "Cu svântul tău nume,"
    },
    {
      "index": 2,
      "text": "Fă-mi giudeț pre lume"
    },
    {
      "index": 3,
      "text": "Și-ntreg mă ferește."
    },
    {
      "index": 4,
      "text": "Cu a ta putere,"
    },
    {
      "index": 5,
      "text": "Grije când am multă,"
    },
    {
      "index": 6,
      "text": "Tu, Doamne, mi-ascultă"
    },
    {
      "index": 7,
      "text": "Ruga din tăcere."
    },
    {
      "index": 8,
      "text": "Că să rădicară"
    },
    {
      "index": 9,
      "text": "Asupră-mi păgânii"
    },
    {
      "index": 10,
      "text": "Și cu toț streinii,"
    },
    {
      "index": 11,
      "text": "De mă-mpresurară."
    },
    {
      "index": 12,
      "text": "Și nu-ț au de frică,"
    },
    {
      "index": 13,
      "text": "Când svântul tău nume,"
    },
    {
      "index": 14,
      "text": "Ce-i vestit în lume,"
    },
    {
      "index": 15,
      "text": "L-iau într-o nemică."
    },
    {
      "index": 16,
      "text": "Ce mie mi-i vântă"
    },
    {
      "index": 17,
      "text": "Domnul, sufletește,"
    },
    {
      "index": 18,
      "text": "De sunt și trupește"
    },
    {
      "index": 19,
      "text": "Întreg, fără smântă."
    },
    {
      "index": 20,
      "text": "Cine mi-s cu scârbă,"
    },
    {
      "index": 21,
      "text": "Le va veni răul"
    },
    {
      "index": 22,
      "text": "Din tot de-adevărul"
    },
    {
      "index": 23,
      "text": "Și le-a cădea-n gârbă."
    },
    {
      "index": 24,
      "text": "Veste preste lume,"
    },
    {
      "index": 25,
      "text": "Doamne, îț voi face,"
    },
    {
      "index": 26,
      "text": "Cu jârtve de pace,"
    },
    {
      "index": 27,
      "text": "Svântului tău nume."
    },
    {
      "index": 28,
      "text": "Că mi-i cu ferice"
    },
    {
      "index": 29,
      "text": "Când tu mă vei scoate"
    },
    {
      "index": 30,
      "text": "Din scârbele toate,"
    },
    {
      "index": 31,
      "text": "Să n-aibă să-m strice"
    },
    {
      "index": 32,
      "text": "Pizmașii, să-m caute,"
    },
    {
      "index": 33,
      "text": "Și-ntr-a lor cădere,"
    },
    {
      "index": 34,
      "text": "Stând fără scădere,"
    },
    {
      "index": 35,
      "text": "Să-i văz de departe."
    }
  ]
}