{
  "title": "Psalmul 133 (Psalm 133)",
  "paragraphs": [
    {
      "index": 0,
      "text": "Iată acmu faceț mulțămită"
    },
    {
      "index": 1,
      "text": "Lui"
    },
    {
      "index": 2,
      "text": "Dumnezău, cu rugă priimită,"
    },
    {
      "index": 3,
      "text": "Și să-l cuvântaț bine-n tot omul,"
    },
    {
      "index": 4,
      "text": "Șerbii toț ce slujiț pregiur"
    },
    {
      "index": 5,
      "text": "Domnul,"
    },
    {
      "index": 6,
      "text": "Carii dvoriț la"
    },
    {
      "index": 7,
      "text": "Domnul în casă,"
    },
    {
      "index": 8,
      "text": "În curțâle cele de mătasă."
    },
    {
      "index": 9,
      "text": "Și nopțâle țâind dvorbă lungă, Vă rădicaț mânule pre rugă, În locurile lui cele svinte, Cu rugăciuni la Domnul priìmite."
    },
    {
      "index": 10,
      "text": "Și ca să-ț dea bună cuvântare"
    },
    {
      "index": 11,
      "text": "Dumnezău din Sion și spori mare, Ce-au poruncit sângur cu cuvântul De s-au făcut ceriul și pământul."
    }
  ]
}