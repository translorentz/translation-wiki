{
  "title": "Psalmul 2 (Psalm 2)",
  "paragraphs": [
    {
      "index": 0,
      "text": "Ce poate fi de poveste,"
    },
    {
      "index": 1,
      "text": "Ca aceasta, și de veste,"
    },
    {
      "index": 2,
      "text": "De să zborâră păgânii,"
    },
    {
      "index": 3,
      "text": "Gloate, tineri și bătrânii,"
    },
    {
      "index": 4,
      "text": "De să vorovăsc cu svaturi"
    },
    {
      "index": 5,
      "text": "În deșert din toate laturi!"
    },
    {
      "index": 6,
      "text": "Și sfătuiesc necurațâi,"
    },
    {
      "index": 7,
      "text": "Cu craii și cu-mpărațâi,"
    },
    {
      "index": 8,
      "text": "Și cu toțâi să-nvitează"
    },
    {
      "index": 9,
      "text": "Spre Domnul, de vor să piarză"
    },
    {
      "index": 10,
      "text": "Pre alesul lui și svântul"
    },
    {
      "index": 11,
      "text": "Iubit fiiul și cuvântul."
    },
    {
      "index": 12,
      "text": "Iară noi, svânta sămânță,"
    },
    {
      "index": 13,
      "text": "Să nu dăm cu dânș în sâlță."
    },
    {
      "index": 14,
      "text": "Legătura să le spargem,"
    },
    {
      "index": 15,
      "text": "În giugul lor să nu tragem."
    },
    {
      "index": 16,
      "text": "Că Dumnezău toate vede"
    },
    {
      "index": 17,
      "text": "Din scaunul său ce șede"
    },
    {
      "index": 18,
      "text": "În ceri, unde odihnește,"
    },
    {
      "index": 19,
      "text": "De-acoló pre toț prăvește."
    },
    {
      "index": 20,
      "text": "Pre pizmașii și pârâșii"
    },
    {
      "index": 21,
      "text": "Domnul va râde de înșii"
    },
    {
      "index": 22,
      "text": "Și-i va mustra de ocară"
    },
    {
      "index": 23,
      "text": "Pentru carea-l supărară."
    },
    {
      "index": 24,
      "text": "Cu mânie le va zâce"
    },
    {
      "index": 25,
      "text": "A ce stătură cu price"
    },
    {
      "index": 26,
      "text": "Și-i va turbura-n urgie"
    },
    {
      "index": 27,
      "text": "De muncile cu vecie."
    },
    {
      "index": 28,
      "text": "Iară eu-s pus de Domnul"
    },
    {
      "index": 29,
      "text": "Crai pre muntele Sionul,"
    },
    {
      "index": 30,
      "text": "Ca să-i spui de-nvățătură"
    },
    {
      "index": 31,
      "text": "Ce poroncește-n scriptură."
    },
    {
      "index": 32,
      "text": "Cătră mine Domnul zâce:"
    },
    {
      "index": 33,
      "text": "„Fiiul mieu ești din mătrice,"
    },
    {
      "index": 34,
      "text": "Eu astăz te nasc pre tine."
    },
    {
      "index": 35,
      "text": "Și vei cere de la mine"
    },
    {
      "index": 36,
      "text": "De-ț voi da limbile toate,"
    },
    {
      "index": 37,
      "text": "Ce țî-s ocină de soarte,"
    },
    {
      "index": 38,
      "text": "Că-ț vor asculta cuvântul"
    },
    {
      "index": 39,
      "text": "Și vei domni-n tot pământul."
    },
    {
      "index": 40,
      "text": "Și-i vei paște cu toiagul"
    },
    {
      "index": 41,
      "text": "Cel de fier în tot șireagul,"
    },
    {
      "index": 42,
      "text": "De vei face-ntr-înșii cârduri"
    },
    {
      "index": 43,
      "text": "Și-i zdrobi ca nește hârburi”."
    },
    {
      "index": 44,
      "text": "Iar acmu voi, împărațâi,"
    },
    {
      "index": 45,
      "text": "Sama vă luaț, și alțâi,"
    },
    {
      "index": 46,
      "text": "De vă certaț cu cuvântul"
    },
    {
      "index": 47,
      "text": "Toț ce giudecaț pământul."
    },
    {
      "index": 48,
      "text": "Slujiț Domnului cu teamă"
    },
    {
      "index": 49,
      "text": "Și vă bucuraț cu samă,"
    },
    {
      "index": 50,
      "text": "Să suferiț și certare"
    },
    {
      "index": 51,
      "text": "De la fiiu-său ce are,"
    },
    {
      "index": 52,
      "text": "Să nu să cumva mânie"
    },
    {
      "index": 53,
      "text": "Spre voi Domnul cu urgie."
    },
    {
      "index": 54,
      "text": "Și veț scăpa de la ceata"
    },
    {
      "index": 55,
      "text": "Celóra ce-s de-a direapta,"
    },
    {
      "index": 56,
      "text": "Când urgia lui cea mare"
    },
    {
      "index": 57,
      "text": "Va arde fără-ncetare."
    },
    {
      "index": 58,
      "text": "Atunce va fi ferice"
    },
    {
      "index": 59,
      "text": "De ceia ce nu pun price,"
    },
    {
      "index": 60,
      "text": "Ce cu inemă direaptă"
    },
    {
      "index": 61,
      "text": "Nedejdiuiesc să ia plată."
    }
  ]
}