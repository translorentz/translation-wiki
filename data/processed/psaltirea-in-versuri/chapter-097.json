{
  "title": "Psalmul 102 (Psalm 102)",
  "paragraphs": [
    {
      "index": 0,
      "text": "Sufletul mieu, zî de bine"
    },
    {
      "index": 1,
      "text": "Domnului cu tot din tine Și pănă ce ești pre lume"
    },
    {
      "index": 2,
      "text": "Să-i fericești svântul nume. Sufletul mieu, zî de Domnul"
    },
    {
      "index": 3,
      "text": "Cuvânt bun cătră tot omul Și să nu-i uiț de bine"
    },
    {
      "index": 4,
      "text": "Ce-au făcut milă cu tine, De te-au spălat de păcate"
    },
    {
      "index": 5,
      "text": "Și ț-au datu-ț sănătate, Și ț-au avutu-ț de știre,"
    },
    {
      "index": 6,
      "text": "De te-au scos de la pierire, Și ț-au trimisu-ț cunună,"
    },
    {
      "index": 7,
      "text": "Milă cu dar depreună,"
    },
    {
      "index": 8,
      "text": "Și ț-au dat cu céi buni parte Ce-ai poftit de bunătate."
    },
    {
      "index": 9,
      "text": "Ca hulturul te-a-nnoi-te, De-i hi tânăr ca mainte, Domnul care face milă Și giudeț celor cu sâlă."
    },
    {
      "index": 10,
      "text": "Calea sa Domnul cea svântă Ne-au arătat fără smântă, Puind pre Moiséi povață."
    },
    {
      "index": 11,
      "text": "Să ne poarte fără greață, Să nu ne-abatem din cale, Din voia svințiii-sale."
    },
    {
      "index": 12,
      "text": "Milosu-i și-ndurat Domnul Că rabdă-ndelung pre omul, Și cu mila sa cea mare Ne ferește de certare."
    },
    {
      "index": 13,
      "text": "Nu ne țâne-n veci mânie Prin păcate, cu urgie, Nice ne-au făcut pre vină, Să ne dea certare plină, Prin greșele și păcate, Să ne dea cu răutate."
    },
    {
      "index": 14,
      "text": "Pre cât stă ceriul departe"
    },
    {
      "index": 15,
      "text": "De pământ de să desparte,"
    },
    {
      "index": 16,
      "text": "Pre-atâta ș-au pusu-ș"
    },
    {
      "index": 17,
      "text": "Domnul"
    },
    {
      "index": 18,
      "text": "Mila sa preste tot omul,"
    },
    {
      "index": 19,
      "text": "Pre ceia ce-i sunt cu teamă,"
    },
    {
      "index": 20,
      "text": "De-l iubăsc fără de samă."
    },
    {
      "index": 21,
      "text": "Câtu-i de la scăpătate Răsăritul de departe, Pre-atâta ne depărtează"
    },
    {
      "index": 22,
      "text": "Greșala, să nu ne piarză."
    },
    {
      "index": 23,
      "text": "Și ca tatăl ce i-i milă De hiii săi când li-i sâlă, Așe nu să-ndură Domnul, Ce i-i milă de tot omul."
    },
    {
      "index": 24,
      "text": "Că sângur ne ști de faptă, Din ce ni-i hirea lucrată, Ne ști că súntem din tină Făcuț, de svânta sa mână."
    },
    {
      "index": 25,
      "text": "De ne-ar hi zâlele multe"
    },
    {
      "index": 26,
      "text": "Ca iarba, tot ar hi scurte,"
    },
    {
      "index": 27,
      "text": "Și ca floarea ce să trece"
    },
    {
      "index": 28,
      "text": "De soare și de vânt rece,"
    },
    {
      "index": 29,
      "text": "De să destramă cu totul"
    },
    {
      "index": 30,
      "text": "Și nu-ș mai cunoaște locul."
    },
    {
      "index": 31,
      "text": "Iară mila ta cea mare Stă din veci pre așezare, Pre-aceia ce-ț veghe voaie, Să nu ducă-n veci nevoaie."
    },
    {
      "index": 32,
      "text": "Și svânta ta dereptate Le va fi cu bunătate, Cu hiii și cu nepoțâi Le vei da bine cu toțâi, Ce-ț feriră giurământul Șiă-țî țânură-ntreg cuvântul."
    },
    {
      "index": 33,
      "text": "Că tu, Dumnezău Domn svinte, Ești în scaun de mainte, Cu crăie așezată În ceri, unde ți-i gătată."
    },
    {
      "index": 34,
      "text": "Blagosloviț cu tot sfatul, Îngerii toț, pre-mpăratul,"
    },
    {
      "index": 35,
      "text": "Toț puternicii cei tare, Ce-i súnteț supt ascultare."
    },
    {
      "index": 36,
      "text": "Dațî-i bună cuvântare, Oștile lui cele tare, Carii slujiț fără smântă"
    },
    {
      "index": 37,
      "text": "Voia Domnului cea svântă."
    },
    {
      "index": 38,
      "text": "Blagosloviț toț pre Domnul, De tutinderea tot omul."
    },
    {
      "index": 39,
      "text": "Și tu, mișelul mieu suflet, Să-i mulțămești cu-ntreg cuget, Și-i urează de tot bine Lui Dumnezău dintru tine."
    },
    {
      "index": 40,
      "text": "Sufletul mieu, ură bine"
    },
    {
      "index": 41,
      "text": "Lui Dumnezău, cum să vine,"
    },
    {
      "index": 42,
      "text": "Și-i zî, Doamne, să trăiască"
    },
    {
      "index": 43,
      "text": "Mărirea ta și să crească."
    },
    {
      "index": 44,
      "text": "Să te-mbraci cu mărturie,"
    },
    {
      "index": 45,
      "text": "Cu frâmsețe și tărie,"
    },
    {
      "index": 46,
      "text": "Că tu te-nvești cu lumină,"
    },
    {
      "index": 47,
      "text": "Ca soarele-n zî senină."
    },
    {
      "index": 48,
      "text": "Și ț-ai tins ceriul ca cortul,"
    },
    {
      "index": 49,
      "text": "De l-ai înfrâmșat cu totul,"
    },
    {
      "index": 50,
      "text": "Și i-ai pus deasupra ape,"
    },
    {
      "index": 51,
      "text": "Din tinsori să nu să scape."
    },
    {
      "index": 52,
      "text": "Núorii ț-ai pusu-ț scară,"
    },
    {
      "index": 53,
      "text": "Când vei să pogori în țară."
    },
    {
      "index": 54,
      "text": "Caii îț sunt iuț ca vântul,"
    },
    {
      "index": 55,
      "text": "De mărg unde ți-i cuvântul,"
    },
    {
      "index": 56,
      "text": "Și ca gândul mărg de tare"
    },
    {
      "index": 57,
      "text": "Îngerii tăi cei călare,"
    },
    {
      "index": 58,
      "text": "Și pedestrimea ca focul"
    },
    {
      "index": 59,
      "text": "Merge strălucind cu totul."
    },
    {
      "index": 60,
      "text": "Tu-ntemeiez cu cuvântul"
    },
    {
      "index": 61,
      "text": "De stă nemutat pământul."
    },
    {
      "index": 62,
      "text": "Tu i-ai datu-i de mainte"
    },
    {
      "index": 63,
      "text": "Prăpastea de-mbrăcăminte,"
    },
    {
      "index": 64,
      "text": "Și stă gata să te-asculte,"
    },
    {
      "index": 65,
      "text": "Să dea apa preste munte,"
    },
    {
      "index": 66,
      "text": "Și de svânta ta poruncă"
    },
    {
      "index": 67,
      "text": "Va fugi din deal la luncă,"
    },
    {
      "index": 68,
      "text": "Că va merge detunată,"
    },
    {
      "index": 69,
      "text": "De glasul tău înspăimată."
    },
    {
      "index": 70,
      "text": "Și munțâi, și dealuri nalte"
    },
    {
      "index": 71,
      "text": "S-or ivi, și șesuri late,"
    },
    {
      "index": 72,
      "text": "Pre locul ce sunt urzâte,"
    },
    {
      "index": 73,
      "text": "Când i-ai făcut de mainte"
    },
    {
      "index": 74,
      "text": "Și le-ai pusu-le hotară,"
    },
    {
      "index": 75,
      "text": "Să nu dea din loc afară,"
    },
    {
      "index": 76,
      "text": "Ce să-ț țâie-ntreg cuvântul,"
    },
    {
      "index": 77,
      "text": "Să nu-mprésure pământul."
    },
    {
      "index": 78,
      "text": "Tu trimiț ape prin tăuri,"
    },
    {
      "index": 79,
      "text": "De cură printre munț răuri,"
    },
    {
      "index": 80,
      "text": "De să toate heri adapă"
    },
    {
      "index": 81,
      "text": "Și le prisosește apă."
    },
    {
      "index": 82,
      "text": "Și colunii când li-i sete"
    },
    {
      "index": 83,
      "text": "Tu-i adăpi fără scumpete."
    },
    {
      "index": 84,
      "text": "Tu strângi pasările-n hoarbă"
    },
    {
      "index": 85,
      "text": "La părău ce vin să soarbă,"
    },
    {
      "index": 86,
      "text": "De prin pietri, de prin gauri"
    },
    {
      "index": 87,
      "text": "Slobod cântece și glasuri."
    },
    {
      "index": 88,
      "text": "Tu sloboz roauă pre munte"
    },
    {
      "index": 89,
      "text": "Dintr-a tale cămări multe,"
    },
    {
      "index": 90,
      "text": "Și pre pământ sloboz ploaie,"
    },
    {
      "index": 91,
      "text": "De să satură-n pohoaie,"
    },
    {
      "index": 92,
      "text": "Și cu lucrul tău sporește"
    },
    {
      "index": 93,
      "text": "Tot pământul de rodește."
    },
    {
      "index": 94,
      "text": "Tu dai fânului să crească,"
    },
    {
      "index": 95,
      "text": "Dobitoacelor să pască."
    },
    {
      "index": 96,
      "text": "Și crești pajiștea cea moale,"
    },
    {
      "index": 97,
      "text": "De scoate grâul din foale,"
    },
    {
      "index": 98,
      "text": "De-ș culeg oamenii hrană"
    },
    {
      "index": 99,
      "text": "Să le hie și pre iarnă."
    },
    {
      "index": 100,
      "text": "Că scot pita cu sudoare"
    },
    {
      "index": 101,
      "text": "Să mănânce la răcoare,"
    },
    {
      "index": 102,
      "text": "Din pământ agonisită"
    },
    {
      "index": 103,
      "text": "Pre porunca ta cea svântă."
    },
    {
      "index": 104,
      "text": "Și le-ai dat vinul să-ș facă"
    },
    {
      "index": 105,
      "text": "Veselie, să le placă."
    },
    {
      "index": 106,
      "text": "Cu oloi să-ș netezască"
    },
    {
      "index": 107,
      "text": "Fața și să să-ncrăvască1"
    },
    {
      "index": 108,
      "text": "Cu pâinea cea de mâncare,"
    },
    {
      "index": 109,
      "text": "Să să facă omul tare."
    },
    {
      "index": 110,
      "text": "Copacilor de pre câmpuri"
    },
    {
      "index": 111,
      "text": "Tu le dai sațâu pre timpuri,"
    },
    {
      "index": 112,
      "text": "Și chedrilor din Livanul,"
    },
    {
      "index": 113,
      "text": "Ce-i răsădești pre tot anul."
    },
    {
      "index": 114,
      "text": "Acoló vrabii ș-or face"
    },
    {
      "index": 115,
      "text": "Cuiburi, di-or ședea cu pace,"
    },
    {
      "index": 116,
      "text": "Că le este rodionul"
    },
    {
      "index": 117,
      "text": "Povață, pus de la Domnul."
    },
    {
      "index": 118,
      "text": "Cerbilor le-ai dat să salte"
    },
    {
      "index": 119,
      "text": "Pre munțâi cu dealuri nalte,"
    },
    {
      "index": 120,
      "text": "Și iepurilor scăpare"
    },
    {
      "index": 121,
      "text": "Le-ai dat s-aibă supt stânci tare."
    },
    {
      "index": 122,
      "text": "Luna ai făcut cu rază,"
    },
    {
      "index": 123,
      "text": "Să crească-n vremi și să scază,"
    },
    {
      "index": 124,
      "text": "Și soarele ș-nemerește"
    },
    {
      "index": 125,
      "text": "Apusul ce odihnește."
    },
    {
      "index": 126,
      "text": "Din tunerec feceș noapte,"
    },
    {
      "index": 127,
      "text": "De ies gadinile toate."
    },
    {
      "index": 128,
      "text": "Lupii urlă și scâncează,"
    },
    {
      "index": 129,
      "text": "Când spre vânat să gătează,"
    },
    {
      "index": 130,
      "text": "Să-ș ceie și să-ș răpască"
    },
    {
      "index": 131,
      "text": "De la Domnul să-i hrănească,"
    },
    {
      "index": 132,
      "text": "Pănă când răsare soare,"
    },
    {
      "index": 133,
      "text": "De mărg cineș la-nchisoare."
    },
    {
      "index": 134,
      "text": "Și omul, fără de greață,"
    },
    {
      "index": 135,
      "text": "Iese-n treabă demineață,"
    },
    {
      "index": 136,
      "text": "De lucrează pănă-n sară,"
    },
    {
      "index": 137,
      "text": "Zî de iarnă și de vară."
    },
    {
      "index": 138,
      "text": "Pentr-aceea, Doamne svinte,"
    },
    {
      "index": 139,
      "text": "Să fii mărit de mainte,"
    },
    {
      "index": 140,
      "text": "De lucruri ce-ai făcut mare,"
    },
    {
      "index": 141,
      "text": "Cu sfat bun, cu așezare!"
    },
    {
      "index": 142,
      "text": "Pământul îi plin de fapte"
    },
    {
      "index": 143,
      "text": "Ce-ai făcut cu bunătate."
    },
    {
      "index": 144,
      "text": "Și marea, câtu-i de lată,"
    },
    {
      "index": 145,
      "text": "Și largă, și desfătată,"
    },
    {
      "index": 146,
      "text": "Într-însă să țin heri multe,"
    },
    {
      "index": 147,
      "text": "Jigănii mari și mănunte."
    },
    {
      "index": 148,
      "text": "Preste luciu de genune"
    },
    {
      "index": 149,
      "text": "Trec corabii cu minune."
    },
    {
      "index": 150,
      "text": "Acoló le vine toană"
    },
    {
      "index": 151,
      "text": "De fac chiții gioc și goană."
    },
    {
      "index": 152,
      "text": "Și toate la tine caută"
    },
    {
      "index": 153,
      "text": "Să le dai hrană bogată,"
    },
    {
      "index": 154,
      "text": "Să strângă și să-ș culeagă"
    },
    {
      "index": 155,
      "text": "Ce le-ai dat, cu voaie largă."
    },
    {
      "index": 156,
      "text": "Cându-ț deșchiz svânta mână,"
    },
    {
      "index": 157,
      "text": "Atunci toată lumea i-plină"
    },
    {
      "index": 158,
      "text": "De bișug și de dulceață,"
    },
    {
      "index": 159,
      "text": "Și-ș petrec toț bine-n viață."
    },
    {
      "index": 160,
      "text": "Și când ț-ascunz fața svântă,"
    },
    {
      "index": 161,
      "text": "Toată lumea să-nspământă."
    },
    {
      "index": 162,
      "text": "Când le iei duhul, s-or stânge"
    },
    {
      "index": 163,
      "text": "Și la țărna lor s-or strânge."
    },
    {
      "index": 164,
      "text": "Duhul tău când li-i trimite,"
    },
    {
      "index": 165,
      "text": "Să vor zidi ca mainte,"
    },
    {
      "index": 166,
      "text": "Și cum ț-ai datu-ț cuvântul,"
    },
    {
      "index": 167,
      "text": "Vei înnoi tot pământul."
    },
    {
      "index": 168,
      "text": "Și să-ț fie, Doamne svinte,"
    },
    {
      "index": 169,
      "text": "Slava-n veci, ca și mainte!"
    },
    {
      "index": 170,
      "text": "Dumnezău gând bun va pune"
    },
    {
      "index": 171,
      "text": "De lucruri ce-au făcut bune."
    },
    {
      "index": 172,
      "text": "Că de svânta ta căutare"
    },
    {
      "index": 173,
      "text": "Pământul tremură tare,"
    },
    {
      "index": 174,
      "text": "Și din munte merge pară,"
    },
    {
      "index": 175,
      "text": "Când pogori să vez în țară."
    },
    {
      "index": 176,
      "text": "Și ț-voi cânta, Doamne,-n viață,"
    },
    {
      "index": 177,
      "text": "În custul mieu, cu dulceață,"
    },
    {
      "index": 178,
      "text": "Cânta-ț-voi, Dumnezău svinte,"
    },
    {
      "index": 179,
      "text": "Domnului mieu de mainte."
    },
    {
      "index": 180,
      "text": "Pănă ce voi fi cu viață,"
    },
    {
      "index": 181,
      "text": "Îț voi cânta fără greață."
    },
    {
      "index": 182,
      "text": "Și să-ț placă, Doamne svinte,"
    },
    {
      "index": 183,
      "text": "Bietele mele cuvinte,"
    },
    {
      "index": 184,
      "text": "Să mă bucur în tot bine"
    },
    {
      "index": 185,
      "text": "De Dumnezău, cum să vine,"
    },
    {
      "index": 186,
      "text": "Ca să pieie cu ocară"
    },
    {
      "index": 187,
      "text": "Toț pizmașii tăi din țară."
    },
    {
      "index": 188,
      "text": "Și ceia ce-s fără lege"
    },
    {
      "index": 189,
      "text": "De pre pământ să vor șterge,"
    },
    {
      "index": 190,
      "text": "Să nu scape nice urmă,"
    },
    {
      "index": 191,
      "text": "Ce să-i ștergi dintr-a ta turmă."
    }
  ]
}