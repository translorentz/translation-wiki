{
  "title": "Psalmul 135 (Psalm 135)",
  "paragraphs": [
    {
      "index": 0,
      "text": "Mărturisiț pre Domnul*,"
    },
    {
      "index": 1,
      "text": "Că-i bun cătră tot omul,"
    },
    {
      "index": 2,
      "text": "Și mila lui trăiește"
    },
    {
      "index": 3,
      "text": "Pre veci de să lățește."
    },
    {
      "index": 4,
      "text": "Vă mărturisiț tare"
    },
    {
      "index": 5,
      "text": "Lui Dumnezău ce-i mare"
    },
    {
      "index": 6,
      "text": "Și-i spuneț dereptatea"
    },
    {
      "index": 7,
      "text": "Pre veci în toată partea."
    },
    {
      "index": 8,
      "text": "Celúia ce domnește"
    },
    {
      "index": 9,
      "text": "Preste domni, de-i sporește,"
    },
    {
      "index": 10,
      "text": "Mila lui cea nălțată"
    },
    {
      "index": 11,
      "text": "Pre veci îi măsurată."
    },
    {
      "index": 12,
      "text": "Ce-au făcut minuni mare,"
    },
    {
      "index": 13,
      "text": "Daț veste de dâns tare,"
    },
    {
      "index": 14,
      "text": "Că i-i mila vestită,"
    },
    {
      "index": 15,
      "text": "Preste veci socotită."
    },
    {
      "index": 16,
      "text": "Ce-au fapt ceriul cu gândul"
    },
    {
      "index": 17,
      "text": "De-ș țâne-ntreg tot rândul,"
    },
    {
      "index": 18,
      "text": "Cu mila sa cea mare,"
    },
    {
      "index": 19,
      "text": "Ce-i în veci pre-așezare."
    },
    {
      "index": 20,
      "text": "Ș-au închegat pământul"
    },
    {
      "index": 21,
      "text": "Dintr-apă cu cuvântul,"
    },
    {
      "index": 22,
      "text": "A lui milă să știe"
    },
    {
      "index": 23,
      "text": "Că-i cruțată-n vecie."
    },
    {
      "index": 24,
      "text": "Făcut-au lumini mare,"
    },
    {
      "index": 25,
      "text": "De dau raze și zare,"
    },
    {
      "index": 26,
      "text": "Cu a sa milă svântă"
    },
    {
      "index": 27,
      "text": "Ce stă-n veci fără smântă."
    },
    {
      "index": 28,
      "text": "Soarelui i-au dat s-aibă"
    },
    {
      "index": 29,
      "text": "Să facă zuă albă,"
    },
    {
      "index": 30,
      "text": "Să sloboaze lucoare,"
    },
    {
      "index": 31,
      "text": "Prin milă stătătoare."
    },
    {
      "index": 32,
      "text": "Preste nopț au pus lună"
    },
    {
      "index": 33,
      "text": "Cu stelele-mpreună,"
    },
    {
      "index": 34,
      "text": "Mila sa să-ș arate"
    },
    {
      "index": 35,
      "text": "Pre veci cu bunătate."
    },
    {
      "index": 36,
      "text": "Ce-au bătut în Eghiptul"
    },
    {
      "index": 37,
      "text": "Toată pârga și viptul,"
    },
    {
      "index": 38,
      "text": "Că i-i mila de-atunce"
    },
    {
      "index": 39,
      "text": "Preste veci cu gând dulce."
    },
    {
      "index": 40,
      "text": "Ce-au scos izrailtenii"
    },
    {
      "index": 41,
      "text": "Dintre toț eghiptenii,"
    },
    {
      "index": 42,
      "text": "Făcându-ș în veci nume"
    },
    {
      "index": 43,
      "text": "De milostiv pre lume."
    },
    {
      "index": 44,
      "text": "Cu mâna sa cea mare,"
    },
    {
      "index": 45,
      "text": "Cu brațul său cel tare,"
    },
    {
      "index": 46,
      "text": "Preste veci să-ș arate"
    },
    {
      "index": 47,
      "text": "Mila de bunătate."
    },
    {
      "index": 48,
      "text": "C-au desfăcut prin Mare,"
    },
    {
      "index": 49,
      "text": "Prin cea Roșie, cărare,"
    },
    {
      "index": 50,
      "text": "În veci ca să-ș ivască"
    },
    {
      "index": 51,
      "text": "Mila dumnezăiască,"
    },
    {
      "index": 52,
      "text": "De-au trecut prin genune"
    },
    {
      "index": 53,
      "text": "Izrail cu minune,"
    },
    {
      "index": 54,
      "text": "Mila să-i țâie minte"
    },
    {
      "index": 55,
      "text": "Preste veci înainte."
    },
    {
      "index": 56,
      "text": "Ș-au răsturnat în mare"
    },
    {
      "index": 57,
      "text": "Pre Faraon cel tare,"
    },
    {
      "index": 58,
      "text": "Cu cât i-au fostu-i sâla,"
    },
    {
      "index": 59,
      "text": "Să-ș arate-n veci mila."
    },
    {
      "index": 60,
      "text": "Și gloata sa cea svântă"
    },
    {
      "index": 61,
      "text": "Ș-au purtat fără smântă,"
    },
    {
      "index": 62,
      "text": "Prin locuri de pustie,"
    },
    {
      "index": 63,
      "text": "Făcând milă-n vecie."
    },
    {
      "index": 64,
      "text": "Struncinat-au crai mare,"
    },
    {
      "index": 65,
      "text": "Război dându-le tare,"
    },
    {
      "index": 66,
      "text": "Mila duimnezăiască"
    },
    {
      "index": 67,
      "text": "Preste veci să-ș vestească."
    },
    {
      "index": 68,
      "text": "Și ucisă crai bóinici,"
    },
    {
      "index": 69,
      "text": "Făcând pre-ai săi sfobodnici,"
    },
    {
      "index": 70,
      "text": "Cu mila sa cea mare,"
    },
    {
      "index": 71,
      "text": "Necuprinsă-n hotare."
    },
    {
      "index": 72,
      "text": "Pre Sion Amoreanul"
    },
    {
      "index": 73,
      "text": "L-au ucis cu tot neamul,"
    },
    {
      "index": 74,
      "text": "Prin milă-ndurătoare,"
    },
    {
      "index": 75,
      "text": "Ce-i în veci stătătoare,"
    },
    {
      "index": 76,
      "text": "Și pre Og uriașul"
    },
    {
      "index": 77,
      "text": "L-au rumpt cu tot sălașul,"
    },
    {
      "index": 78,
      "text": "Mila dumnezăiască"
    },
    {
      "index": 79,
      "text": "Cu noi să văcuiască."
    },
    {
      "index": 80,
      "text": "Țara lor cea sămață"
    },
    {
      "index": 81,
      "text": "Au dat să și o-mparță,"
    },
    {
      "index": 82,
      "text": "Mila lui să să vază"
    },
    {
      "index": 83,
      "text": "Preste veci lăsând rază."
    },
    {
      "index": 84,
      "text": "’"
    },
    {
      "index": 85,
      "text": "Să o măsure-n șirul"
    },
    {
      "index": 86,
      "text": "Șerbul său, Izrailul,"
    },
    {
      "index": 87,
      "text": "Ca să-i fie moșie"
    },
    {
      "index": 88,
      "text": "Prin mila sa-n vecie."
    },
    {
      "index": 89,
      "text": "Că la loc de durere"
    },
    {
      "index": 90,
      "text": "Ni-i Domnul mângâiere,"
    },
    {
      "index": 91,
      "text": "Și mila lui cea largă"
    },
    {
      "index": 92,
      "text": "Preste veci tot stă-ntreagă."
    },
    {
      "index": 93,
      "text": "Și când ne vine greul,"
    },
    {
      "index": 94,
      "text": "Ne scoate din tot răul,"
    },
    {
      "index": 95,
      "text": "Că Domnul gând bun poartă În veci pentr-a sa gloată."
    },
    {
      "index": 96,
      "text": "Care dă hrană-n țară, De iarnă și de vară, Și trimite dulceață Cu milă-n veci de viață."
    },
    {
      "index": 97,
      "text": "Și să daț mulțămită Lui Dumnezău priimită, Că ceriul și pământul Cruță-n veci cu cuvântul."
    },
    {
      "index": 98,
      "text": "La apa Vavilonului,"
    },
    {
      "index": 99,
      "text": "Jelind de țara Domnului,"
    },
    {
      "index": 100,
      "text": "Acoló șezum și plânsăm"
    },
    {
      "index": 101,
      "text": "La voroavă ce ne strânsăm,"
    },
    {
      "index": 102,
      "text": "Și cu inemă amară,"
    },
    {
      "index": 103,
      "text": "Prin Sion și pentru țară,"
    },
    {
      "index": 104,
      "text": "Aducându-ne aminte,"
    },
    {
      "index": 105,
      "text": "Plângeam cu lacrămi herbinte."
    },
    {
      "index": 106,
      "text": "Și bucine ferecate"
    },
    {
      "index": 107,
      "text": "Lăsăm prin sălci aninate,"
    },
    {
      "index": 108,
      "text": "Că acoló ne-ntrebară"
    },
    {
      "index": 109,
      "text": "Aceia ce ne prădară"
    },
    {
      "index": 110,
      "text": "Să le zâcem viers de carte"
    },
    {
      "index": 111,
      "text": "Într-acea streinătate,"
    },
    {
      "index": 112,
      "text": "Ca-n svânt muntele Sionul"
    },
    {
      "index": 113,
      "text": "Cântări ce cântam la Domnul."
    },
    {
      "index": 114,
      "text": "Ce nu ni să da-ndemână"
    },
    {
      "index": 115,
      "text": "A cânta-n țară streină."
    },
    {
      "index": 116,
      "text": "De te-aș uita, țară svântă,"
    },
    {
      "index": 117,
      "text": "Atuncea să-mi vie smântă,"
    },
    {
      "index": 118,
      "text": "Și direapta mea să uite"
    },
    {
      "index": 119,
      "text": "A schimba viers în lăute!"
    },
    {
      "index": 120,
      "text": "Și să mi să prinză limba"
    },
    {
      "index": 121,
      "text": "De gingini, jelindu-mi scârba,"
    },
    {
      "index": 122,
      "text": "De te-aș mai putea uita-te,"
    },
    {
      "index": 123,
      "text": "Ierusalim cetate,"
    },
    {
      "index": 124,
      "text": "Nainte de nu te-aș pune"
    },
    {
      "index": 125,
      "text": "În pomene-n zâle bune."
    },
    {
      "index": 126,
      "text": "Să nu uíț, Doamne svinte,"
    },
    {
      "index": 127,
      "text": "De Edom ce-au zâs cuvinte"
    },
    {
      "index": 128,
      "text": "Svintei cetăț împrotivă,"
    },
    {
      "index": 129,
      "text": "Cu rău din gură zlobivă :"
    },
    {
      "index": 130,
      "text": "„Răsâpițî-i zidiuri nalte,"
    },
    {
      "index": 131,
      "text": "Deșertaț de bunătate!“"
    },
    {
      "index": 132,
      "text": "Tu, fată vavilonească,"
    },
    {
      "index": 133,
      "text": "Răul va să te tâlnească!"
    },
    {
      "index": 134,
      "text": "Va fi ș-acela-n ferice"
    },
    {
      "index": 135,
      "text": "Ce-ț-va veni să te strice,"
    },
    {
      "index": 136,
      "text": "Că țî să va-ntoarce darul,"
    },
    {
      "index": 137,
      "text": "Cum ne-nchini tu cu păharul,"
    },
    {
      "index": 138,
      "text": "Când cuconii tăi de ziduri"
    },
    {
      "index": 139,
      "text": "Vor zdrobi-i ca nește hârburi."
    }
  ]
}