{
  "title": "Psalmul 95 (Psalm 95)",
  "paragraphs": [
    {
      "index": 0,
      "text": "Cântaț Domnului cu cinste Cântec nou, ca de mainte, Și-i cântaț din tot pământul, Să vă margă-n sus cuvântul."
    },
    {
      "index": 1,
      "text": "Cântaț și-i zâcéț ferice Domnului, și să-i rădice Toț cu cinste svântul nume, Să-l auză preste lume."
    },
    {
      "index": 2,
      "text": "Să-i strigaț și veste bună, Den zî în zî depreună, De svânta lui mântuire, Și la păgâni să daț știre"
    },
    {
      "index": 3,
      "text": "De slava lui, de ciudese, Să s-auză-n gloate dese, Că mare Domn este Domnul Și lăudat în tot omul."
    },
    {
      "index": 4,
      "text": "De groznic să stea să-l vază Dumnezăii nu cutează."
    },
    {
      "index": 5,
      "text": "Păgânii nu-ș scoață-n fală Cu bozâi cei de sminteală, Că dintr-înș le răspund dracii, Cându-ș închină colacii."
    },
    {
      "index": 6,
      "text": "Iară Domnul i să știe Că-i Dumnezău în vecie, Ceriurile cu cuvântul Le-au făcut, și tot pământul."
    },
    {
      "index": 7,
      "text": "Denaintea lui cu teamă Dvoresc îngeri fără samă, De-l mărturisesc și-l cântă În frâmsețea lui cea svântă."
    },
    {
      "index": 8,
      "text": "Păgâni din toate răgúle, Veniț cu daruri destule,"
    },
    {
      "index": 9,
      "text": "Aduceț Domnului slavă,"
    },
    {
      "index": 10,
      "text": "Aduceț fără zăbavă."
    },
    {
      "index": 11,
      "text": "Să-i slăviț cinstitul nume"
    },
    {
      "index": 12,
      "text": "Toate neamuri de pre lume."
    },
    {
      "index": 13,
      "text": "Aduceț colaci grămadă În cinstita lui ogradă Și să vă-nchinaț tot omul În curtea ce șede Domnul."
    },
    {
      "index": 14,
      "text": "De fața dumnezăiască Pământul să să clătească."
    },
    {
      "index": 15,
      "text": "Spuneț în păgâni să știe"
    },
    {
      "index": 16,
      "text": "Că Domnul luă crăie, Se șează să-mpărățască Și lumea să o-ntărească, Tuturor pre așezare Să le facă giudecare."
    },
    {
      "index": 17,
      "text": "Ceriul s-aibă voaie bună, Cu pământul depreună, Și marea giucând să salte Cu unde, cu valuri nalte."
    },
    {
      "index": 18,
      "text": "Și câmpii încă să-ș facă Bucurie, să le placă."
    },
    {
      "index": 19,
      "text": "Atunce s-a bucura-să Toată dumbrava cea deasă De fața lui de cea svântă, Ce va veni fără smântă."
    },
    {
      "index": 20,
      "text": "Fără greș va veni Domnul De va giudeca tot omul, Și cu lege așezată Va giudeca de-a da plată."
    },
    {
      "index": 21,
      "text": "Domnul stătu crai în"
    },
    {
      "index": 22,
      "text": "Țărâle să bucurară,"
    },
    {
      "index": 23,
      "text": "Și pământul tot să salte,"
    },
    {
      "index": 24,
      "text": "Cu ostrove de departe."
    },
    {
      "index": 25,
      "text": "Dimpregiur núor și ceață"
    },
    {
      "index": 26,
      "text": "Sprejinesc svânta lui față,"
    },
    {
      "index": 27,
      "text": "Și direptatea-i tocmește"
    },
    {
      "index": 28,
      "text": "Scaunul ce odihnește,"
    },
    {
      "index": 29,
      "text": "De-l gătează pre giudețe,"
    },
    {
      "index": 30,
      "text": "Ne-alegând pre nime-n fețe."
    },
    {
      "index": 31,
      "text": "Pre denainte-i foc merge,"
    },
    {
      "index": 32,
      "text": "De arde cei fără lege."
    },
    {
      "index": 33,
      "text": "Fulgerile lui cu pară"
    },
    {
      "index": 34,
      "text": "Ard de să văd preste țară."
    },
    {
      "index": 35,
      "text": "Pământul să-mplú de frică,"
    },
    {
      "index": 36,
      "text": "Munțâi să topăsc de p"
    },
    {
      "index": 37,
      "text": "Și cură ca nește ceară,"
    },
    {
      "index": 38,
      "text": "Văzând pre Domnul în țară."
    },
    {
      "index": 39,
      "text": "Și de fața lui cea svântă"
    },
    {
      "index": 40,
      "text": "Tot pământul să spământă."
    },
    {
      "index": 41,
      "text": "Ceriurile grăiesc toate,"
    },
    {
      "index": 42,
      "text": "De-i spun dereptatea-n gloate."
    },
    {
      "index": 43,
      "text": "Și toț oamenii văzură"
    },
    {
      "index": 44,
      "text": "Slava lui de să-ncrezură."
    },
    {
      "index": 45,
      "text": "Iară ceia ce-s cu vină"
    },
    {
      "index": 46,
      "text": "Pentru idoli ce să-nchină,"
    },
    {
      "index": 47,
      "text": "Stau cu groază și cu frică,"
    },
    {
      "index": 48,
      "text": "Li-i nedejdea-ntr-o nemică."
    },
    {
      "index": 49,
      "text": "Închinațî-vă la Domnul,"
    },
    {
      "index": 50,
      "text": "Cu toț îngerii, tot omul."
    },
    {
      "index": 51,
      "text": "Sionul să-i paie bine,"
    },
    {
      "index": 52,
      "text": "Auzând că Domnul vine."
    },
    {
      "index": 53,
      "text": "Fetele din jidovie"
    },
    {
      "index": 54,
      "text": "Te-aștaptă cu bucurie"
    },
    {
      "index": 55,
      "text": "Pentru svintele giudețe"
    },
    {
      "index": 56,
      "text": "Ce le alegi cu blândețe."
    },
    {
      "index": 57,
      "text": "Că tu, Doamne, ne ești Domnul"
    },
    {
      "index": 58,
      "text": "Pre pământ preste tot omul,"
    },
    {
      "index": 59,
      "text": "Și ți-i nalt cinstitul nume"
    },
    {
      "index": 60,
      "text": "Preste toț bozâi din lume."
    },
    {
      "index": 61,
      "text": "Ceia ce iubiț pre Domnul,"
    },
    {
      "index": 62,
      "text": "Să urâț răul, tot omul."
    },
    {
      "index": 63,
      "text": "Că Dumnezău îș ferește"
    },
    {
      "index": 64,
      "text": "Ceata de svinț ce-l iubește,"
    },
    {
      "index": 65,
      "text": "Și din mâni fără de lege"
    },
    {
      "index": 66,
      "text": "I-a scoate și-i va alege."
    },
    {
      "index": 67,
      "text": "Și direptului senină"
    },
    {
      "index": 68,
      "text": "Îi va străluci lumină,"
    },
    {
      "index": 69,
      "text": "Veselie și cunună"
    },
    {
      "index": 70,
      "text": "Celor cu inemă bună."
    },
    {
      "index": 71,
      "text": "Și vă bucuraț, tot omul"
    },
    {
      "index": 72,
      "text": "Ce sunteț direpț, la Domnul,"
    },
    {
      "index": 73,
      "text": "Mărturisind fără smântă"
    },
    {
      "index": 74,
      "text": "De pomana lui cea svântă."
    }
  ]
}