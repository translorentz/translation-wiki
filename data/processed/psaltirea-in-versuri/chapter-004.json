{
  "title": "Psalmul 4 (Psalm 4)",
  "paragraphs": [
    {
      "index": 0,
      "text": "Când îț strig cu mare jele"
    },
    {
      "index": 1,
      "text": "Dintr-adâncul de greșele,"
    },
    {
      "index": 2,
      "text": "Dumnezăul bunătățâi,"
    },
    {
      "index": 3,
      "text": "Mi-ai ascultat direptățâi,"
    },
    {
      "index": 4,
      "text": "Și-n vreme de greutate"
    },
    {
      "index": 5,
      "text": "Mi-ai lărgitu-mi pre departe."
    },
    {
      "index": 6,
      "text": "Te-ndură și miluiește"
    },
    {
      "index": 7,
      "text": "Pre mișel ce te dorește"
    },
    {
      "index": 8,
      "text": "Și mi-ascultă mișea rugă,"
    },
    {
      "index": 9,
      "text": "Ce țî-s adevară slugă."
    },
    {
      "index": 10,
      "text": "Răilor, să nu vă paie"
    },
    {
      "index": 11,
      "text": "Dumnezău mila să-ș taie!"
    },
    {
      "index": 12,
      "text": "Ce căce iubiț deșerte,"
    },
    {
      "index": 13,
      "text": "Dumnezău va să vă certe."
    },
    {
      "index": 14,
      "text": "Să vă părăsâț minciuna,"
    },
    {
      "index": 15,
      "text": "Să nu o cercaț deauna,"
    },
    {
      "index": 16,
      "text": "Ce să cunoașteț pre omul"
    },
    {
      "index": 17,
      "text": "Ce și l-au minunat Domnul."
    },
    {
      "index": 18,
      "text": "Că Dumnezău mă ascultă,"
    },
    {
      "index": 19,
      "text": "Când îl strig din grije multă."
    },
    {
      "index": 20,
      "text": "Și când te mânii, nu face"
    },
    {
      "index": 21,
      "text": "Rău altuia, ce nu-ț place."
    },
    {
      "index": 22,
      "text": "Inema ce te sfădește"
    },
    {
      "index": 23,
      "text": "La culcuș o umilește."
    },
    {
      "index": 24,
      "text": "Și fă jărtva cea direaptă,"
    },
    {
      "index": 25,
      "text": "De la Domnul să iei plată."
    },
    {
      "index": 26,
      "text": "Mulț giuruiesc daruri bune"
    },
    {
      "index": 27,
      "text": "Binele cine le-ar spune."
    },
    {
      "index": 28,
      "text": "Iară spre noi, Doamne svinte,"
    },
    {
      "index": 29,
      "text": "Ț-ai însămnat de mainte"
    },
    {
      "index": 30,
      "text": "Strălucoarea svintei fețe,"
    },
    {
      "index": 31,
      "text": "De ne-ntoarce la blândețe."
    },
    {
      "index": 32,
      "text": "De-aceasta m-dai bucurie"
    },
    {
      "index": 33,
      "text": "Inemii și veselie,"
    },
    {
      "index": 34,
      "text": "Ca de casă cu strânsoare,"
    },
    {
      "index": 35,
      "text": "Cu haine tinse la soare."
    },
    {
      "index": 36,
      "text": "Vin și grâu să prisosască,"
    },
    {
      "index": 37,
      "text": "Oloiul să nu lipsască."
    },
    {
      "index": 38,
      "text": "Iară eu cu pace bună"
    },
    {
      "index": 39,
      "text": "Voi adormi depreună,"
    },
    {
      "index": 40,
      "text": "Și când din lume m-ii duce,"
    },
    {
      "index": 41,
      "text": "Mă vei odihni cu dulce,"
    },
    {
      "index": 42,
      "text": "În casa ta cea senină,"
    },
    {
      "index": 43,
      "text": "Cătră nedejde deplină."
    }
  ]
}