{
  "title": "Psalmul 3 (Psalm 3)",
  "paragraphs": [
    {
      "index": 0,
      "text": "Doamne, ce să înmulțâră"
    },
    {
      "index": 1,
      "text": "Ceia ce mă trag cu pâră!"
    },
    {
      "index": 2,
      "text": "Asupră-mi mulț să sculară,"
    },
    {
      "index": 3,
      "text": "Cuvânt mare cuvântară,"
    },
    {
      "index": 4,
      "text": "Dându-ș inemii credință"
    },
    {
      "index": 5,
      "text": "Cum să fiu în oceință,"
    },
    {
      "index": 6,
      "text": "Să n-aib agiutori de tine,"
    },
    {
      "index": 7,
      "text": "Dumnezău, ce-m ești cu bine,"
    },
    {
      "index": 8,
      "text": "La nevoaie sprejineală,"
    },
    {
      "index": 9,
      "text": "Și la voaie îm ești fală."
    },
    {
      "index": 10,
      "text": "Că mi-ai împletit cunună,"
    },
    {
      "index": 11,
      "text": "Cu podoabă depreună,"
    },
    {
      "index": 12,
      "text": "De m-ai pus cap preste alțâi,"
    },
    {
      "index": 13,
      "text": "Să bat pre toț necurațâi."
    },
    {
      "index": 14,
      "text": "Am strigat cu glasul mare"
    },
    {
      "index": 15,
      "text": "Cătră Dumnezău cel tare,"
    },
    {
      "index": 16,
      "text": "Că mi-aude de mi-i vântă"
    },
    {
      "index": 17,
      "text": "Dintr-a sa măgură svântă."
    },
    {
      "index": 18,
      "text": "Am dormit somn cu odihnă"
    },
    {
      "index": 19,
      "text": "Pănă-n zuă de la cină."
    },
    {
      "index": 20,
      "text": "Și m-am sculat demineață,"
    },
    {
      "index": 21,
      "text": "Că mi-i Dumnezău povață."
    },
    {
      "index": 22,
      "text": "De-ntunerece de gloate"
    },
    {
      "index": 23,
      "text": "Teamă n-am, nice mă poate"
    },
    {
      "index": 24,
      "text": "Veste rea să mă mâhnească,"
    },
    {
      "index": 25,
      "text": "Dimpregiur ce-a să-m gârbască."
    },
    {
      "index": 26,
      "text": "Scoală, Doamne, de mă scoate"
    },
    {
      "index": 27,
      "text": "De la scârbe de la toate,"
    },
    {
      "index": 28,
      "text": "Și le dă bătaia-n gârbă"
    },
    {
      "index": 29,
      "text": "A pizmaș ce-m cearcă scârbă."
    },
    {
      "index": 30,
      "text": "Și scârșcând să-ș frângă dinții"
    },
    {
      "index": 31,
      "text": "În durerea sa greșiții."
    },
    {
      "index": 32,
      "text": "Că Dumnezău cu izbândă"
    },
    {
      "index": 33,
      "text": "Va da celor buni dobândă."
    }
  ]
}