{
  "title": "Psalmul 47 (Psalm 47)",
  "paragraphs": [
    {
      "index": 0,
      "text": "Domnul este mare,"
    },
    {
      "index": 1,
      "text": "Lăudat și tare."
    },
    {
      "index": 2,
      "text": "Mai cu de-adins este"
    },
    {
      "index": 3,
      "text": "Lăudat cu veste"
    },
    {
      "index": 4,
      "text": "De-a lui bunătate,"
    },
    {
      "index": 5,
      "text": "În svânta cetate"
    },
    {
      "index": 6,
      "text": "Din măgura svântă,"
    },
    {
      "index": 7,
      "text": "Ce stă fără smântă."
    },
    {
      "index": 8,
      "text": "Cetate frumoasă"
    },
    {
      "index": 9,
      "text": "De piatră vârtoasă,"
    },
    {
      "index": 10,
      "text": "Bine-ntemeiată,"
    },
    {
      "index": 11,
      "text": "De Domnul gătată;"
    },
    {
      "index": 12,
      "text": "În țară-i vestită"
    },
    {
      "index": 13,
      "text": "Câtu-i de tocmită."
    },
    {
      "index": 14,
      "text": "Muntele Sionul"
    },
    {
      "index": 15,
      "text": "Ce ș-au ales Domnul"
    },
    {
      "index": 16,
      "text": "Despre miazănoapte"
    },
    {
      "index": 17,
      "text": "Dă raze cât poate."
    },
    {
      "index": 18,
      "text": "Pre coaste de munte"
    },
    {
      "index": 19,
      "text": "Cu ulițe multe,"
    },
    {
      "index": 20,
      "text": "Cetatea cea mare"
    },
    {
      "index": 21,
      "text": "Craiului cel tare,"
    },
    {
      "index": 22,
      "text": "Cu curț desfătate,"
    },
    {
      "index": 23,
      "text": "Cu pânzele nalte."
    },
    {
      "index": 24,
      "text": "Strajea nu-i lipsește,"
    },
    {
      "index": 25,
      "text": "Domnul o-ntărește."
    },
    {
      "index": 26,
      "text": "Craii și-mpărațâi"
    },
    {
      "index": 27,
      "text": "Ce fac sfat cu alțâi"
    },
    {
      "index": 28,
      "text": "Să strice cetatea,"
    },
    {
      "index": 29,
      "text": "Să-i ia bunătatea,"
    },
    {
      "index": 30,
      "text": "Când ei să adună,"
    },
    {
      "index": 31,
      "text": "Domnul îi detună,"
    },
    {
      "index": 32,
      "text": "Și-i cuprinde frică,"
    },
    {
      "index": 33,
      "text": "De nu pot nemică,"
    },
    {
      "index": 34,
      "text": "Cât stau de să miră"
    },
    {
      "index": 35,
      "text": "A ce să-nglotiră."
    },
    {
      "index": 36,
      "text": "Domnul le dă spaimă"
    },
    {
      "index": 37,
      "text": "Cu munci fără samă,"
    },
    {
      "index": 38,
      "text": "Ca maică când fată"
    },
    {
      "index": 39,
      "text": "De este-nspăimată,"
    },
    {
      "index": 40,
      "text": "Ca vase pre mare"
    },
    {
      "index": 41,
      "text": "Când le ia vânt tare,"
    },
    {
      "index": 42,
      "text": "De le dă de stâncă"
    },
    {
      "index": 43,
      "text": "Și le răzdrumică."
    },
    {
      "index": 44,
      "text": "Auzât-am veche"
    },
    {
      "index": 45,
      "text": "’Ntr-auz de ureche"
    },
    {
      "index": 46,
      "text": "Poveste trecută,"
    },
    {
      "index": 47,
      "text": "Ș-acmu vedem multă,"
    },
    {
      "index": 48,
      "text": "Că Dumnezău toate"
    },
    {
      "index": 49,
      "text": "Câte va, le poate."
    },
    {
      "index": 50,
      "text": "Cu lănci de departe"
    },
    {
      "index": 51,
      "text": "Pre pizmașii bate,"
    },
    {
      "index": 52,
      "text": "Și cetatea svântă"
    },
    {
      "index": 53,
      "text": "Stă fără de smântă,"
    },
    {
      "index": 54,
      "text": "N-are greutate"
    },
    {
      "index": 55,
      "text": "Nice de o parte,"
    },
    {
      "index": 56,
      "text": "Că o-ntemeiază"
    },
    {
      "index": 57,
      "text": "Domnul, să să-ncrează,"
    },
    {
      "index": 58,
      "text": "Și-i tinde-mprotivă"
    },
    {
      "index": 59,
      "text": "Mână milostivă."
    },
    {
      "index": 60,
      "text": "Cât are tot omul"
    },
    {
      "index": 61,
      "text": "Milă de la Domnul."
    },
    {
      "index": 62,
      "text": "Și svântul lui nume"
    },
    {
      "index": 63,
      "text": "Trece preste lume,"
    },
    {
      "index": 64,
      "text": "Svânta lui direaptă"
    },
    {
      "index": 65,
      "text": "Direaptă dă plată."
    },
    {
      "index": 66,
      "text": "Muntele Sionul"
    },
    {
      "index": 67,
      "text": "S-aibă de la Domnul"
    },
    {
      "index": 68,
      "text": "Bucurie plină"
    },
    {
      "index": 69,
      "text": "’N inemă senină"
    },
    {
      "index": 70,
      "text": "De giudeț ce-i face,"
    },
    {
      "index": 71,
      "text": "Și-n zâle de pace"
    },
    {
      "index": 72,
      "text": "Să iasă-mpreună"
    },
    {
      "index": 73,
      "text": "Toț cu voie bună"
    },
    {
      "index": 74,
      "text": "Împregiur cetate"
    },
    {
      "index": 75,
      "text": "Ce-i cu ziduri nalte,"
    },
    {
      "index": 76,
      "text": "Hiica jidovască"
    },
    {
      "index": 77,
      "text": "Turnuri să-ș prăvască."
    },
    {
      "index": 78,
      "text": "Și-ntr-alt rând de lume"
    },
    {
      "index": 79,
      "text": "De svântul tău nume"
    },
    {
      "index": 80,
      "text": "Tot să povestească,"
    },
    {
      "index": 81,
      "text": "Să te proslăvască."
    },
    {
      "index": 82,
      "text": "Să te ști tot omul"
    },
    {
      "index": 83,
      "text": "Că tu ne ești Domnul,"
    },
    {
      "index": 84,
      "text": "Și câț să vor naște"
    },
    {
      "index": 85,
      "text": "Cu tine s-or paște."
    }
  ]
}