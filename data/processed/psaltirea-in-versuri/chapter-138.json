{
  "title": "Psalmul 146 (Psalm 146)",
  "paragraphs": [
    {
      "index": 0,
      "text": "Lăudațî-l cu cântec pre Domnul,"
    },
    {
      "index": 1,
      "text": "Că i-i cântecul bun în tot omul. Și cântări cu dulceață să-i facă"
    },
    {
      "index": 2,
      "text": "Lui Dumnezău de cinste, să-i placă. Că zidește Ierusalimul1,"
    },
    {
      "index": 3,
      "text": "Ca să bage-ntr-îns pre tot creștinul, Și pre tot Izrailul să strângă,"
    },
    {
      "index": 4,
      "text": "Să petreacă-ntr-îns fără de tângă. Cela ce dă leacuri fără smântă"
    },
    {
      "index": 5,
      "text": "Cărora sunt cu inema frântă"
    },
    {
      "index": 6,
      "text": "’"
    },
    {
      "index": 7,
      "text": "Și le leagă frânturi sfărâmate,"
    },
    {
      "index": 8,
      "text": "De-i schimbă din boală-n sănătate, Cela ce-au pus stelelor măsură"
    },
    {
      "index": 9,
      "text": "Și numere careaș pre făptură, Mare este Domnul de tărie,"
    },
    {
      "index": 10,
      "text": "Și gândul lui nime nu-i să-l știe. Domnul pre céi buni îi sprejinește,"
    },
    {
      "index": 11,
      "text": "Și sămețâi la pământ smerește."
    },
    {
      "index": 12,
      "text": "Începeț lui"
    },
    {
      "index": 13,
      "text": "Dumnezău cu strune"
    },
    {
      "index": 14,
      "text": "De-i cântaț cu viers să să răsune,"
    },
    {
      "index": 15,
      "text": "Și să-i cântaț cântec cu dulceață"
    },
    {
      "index": 16,
      "text": "Celuia ce-au tins preste ceri ceață"
    },
    {
      "index": 17,
      "text": "Și gătează cu núorii ploaie"
    },
    {
      "index": 18,
      "text": "De sloboade pre pământ pohoaie,"
    },
    {
      "index": 19,
      "text": "Celuia ce crește pre munț iarbă"
    },
    {
      "index": 20,
      "text": "Și otava ceea ce-i de treabă"
    },
    {
      "index": 21,
      "text": "Pentru oameni, să-ș culeagă hrană,"
    },
    {
      "index": 22,
      "text": "Și vitelor s-aibă preste iarnă,"
    },
    {
      "index": 23,
      "text": "Celuia ce grijește de hiară"
    },
    {
      "index": 24,
      "text": "Și de puii corbilor ce zbiară, Cându-l strigă, urgisiț de tată,"
    },
    {
      "index": 25,
      "text": "De-i hrănește cu mână-ndurată."
    },
    {
      "index": 26,
      "text": "Că"
    },
    {
      "index": 27,
      "text": "Domnul pre cai buni nu să bate,"
    },
    {
      "index": 28,
      "text": "Nice pre vitej cu státuri nalte,"
    },
    {
      "index": 29,
      "text": "Ce"
    },
    {
      "index": 30,
      "text": "Domnului acela om place"
    },
    {
      "index": 31,
      "text": "Ce-i plinește porunca cu pace,"
    },
    {
      "index": 32,
      "text": "Și la vreme de greu și de sâlă"
    },
    {
      "index": 33,
      "text": "Cugetează spre svânta lui milă."
    }
  ]
}