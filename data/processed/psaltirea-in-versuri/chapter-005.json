{
  "title": "Psalmul 5 (Psalm 5)",
  "paragraphs": [
    {
      "index": 0,
      "text": "Sloboz, Doamne,-n urechi svinte"
    },
    {
      "index": 1,
      "text": "Grai cu de jele cuvinte"
    },
    {
      "index": 2,
      "text": "Și mi-ascultă mișea rugă"
    },
    {
      "index": 3,
      "text": "La greu, ce-ț sunt a ta slugă,"
    },
    {
      "index": 4,
      "text": "Dumnezău și împărate,"
    },
    {
      "index": 5,
      "text": "Că mă rog cu dereptate."
    },
    {
      "index": 6,
      "text": "Încă zoare nu răvarsă"
    },
    {
      "index": 7,
      "text": "De soare, când va să iasă,"
    },
    {
      "index": 8,
      "text": "Svinția-ta mi-auz glasul"
    },
    {
      "index": 9,
      "text": "Și mă vez preste tot ceasul."
    },
    {
      "index": 10,
      "text": "Că tu, Doamne,-n fărălege"
    },
    {
      "index": 11,
      "text": "Pre nime nu laș s-alerge."
    },
    {
      "index": 12,
      "text": "Și-n casa ta n-àvea parte"
    },
    {
      "index": 13,
      "text": "Vicleanul, ce-a sta departe."
    },
    {
      "index": 14,
      "text": "Strâmbii nu laș să trăiască,"
    },
    {
      "index": 15,
      "text": "De-aproape să te prăvască,"
    },
    {
      "index": 16,
      "text": "Că de svânta-ț căùtătură"
    },
    {
      "index": 17,
      "text": "S-or face pizmașii zgură."
    },
    {
      "index": 18,
      "text": "Urât-ai pre toț făloșii"
    },
    {
      "index": 19,
      "text": "Și vei pierde mincinoșii."
    },
    {
      "index": 20,
      "text": "Și de om ce varsă sânge"
    },
    {
      "index": 21,
      "text": "Ți-i greață a te atinge."
    },
    {
      "index": 22,
      "text": "Iară eu, Dumnezău svinte,"
    },
    {
      "index": 23,
      "text": "Cu mila ta de mainte,"
    },
    {
      "index": 24,
      "text": "Îț voi intra-n svânta casă,"
    },
    {
      "index": 25,
      "text": "Unde șez, Doamne, la masă,"
    },
    {
      "index": 26,
      "text": "De m-oi închina cu rugă,"
    },
    {
      "index": 27,
      "text": "În frica ta, ce țî-s slugă,"
    },
    {
      "index": 28,
      "text": "În beserica ta svântă."
    },
    {
      "index": 29,
      "text": "Și mă du fără de smântă"
    },
    {
      "index": 30,
      "text": "Spre-adevăr, să nu duc greață,"
    },
    {
      "index": 31,
      "text": "Că tu, Doamne, m-ești povață"
    },
    {
      "index": 32,
      "text": "Și spre tine-m deregi pașii,"
    },
    {
      "index": 33,
      "text": "Ca să nu-m strice pizmașii."
    },
    {
      "index": 34,
      "text": "Că li-i gura nedireaptă"
    },
    {
      "index": 35,
      "text": "Și li-i inema deșartă."
    },
    {
      "index": 36,
      "text": "Cu gâltejele căscate,"
    },
    {
      "index": 37,
      "text": "De izbucnesc răutate,"
    },
    {
      "index": 38,
      "text": "Cu graiuri necuvioase,"
    },
    {
      "index": 39,
      "text": "Ca un mormânt plin de oase."
    },
    {
      "index": 40,
      "text": "Și cu limba lor înșală,"
    },
    {
      "index": 41,
      "text": "Să facă-n lume sminteală."
    },
    {
      "index": 42,
      "text": "Ce le dă, Doamne, osândă,"
    },
    {
      "index": 43,
      "text": "Să nu-ș laude-n dobândă."
    },
    {
      "index": 44,
      "text": "Sfaturile să le piarză"
    },
    {
      "index": 45,
      "text": "Și din mila ta să cază."
    },
    {
      "index": 46,
      "text": "Cu a lor păgânătate,"
    },
    {
      "index": 47,
      "text": "Să-i urnești la răutate,"
    },
    {
      "index": 48,
      "text": "Că te, Doamne, mâniară,"
    },
    {
      "index": 49,
      "text": "Clevetindu-te prin țară."
    },
    {
      "index": 50,
      "text": "Iară ceia ce te-aștaptă,"
    },
    {
      "index": 51,
      "text": "Pre toț să-i bucuri cu plată,"
    },
    {
      "index": 52,
      "text": "Cu tine-n veci să petreacă"
    },
    {
      "index": 53,
      "text": "Bucurie, să le placă."
    },
    {
      "index": 54,
      "text": "Să să laude cu tine"
    },
    {
      "index": 55,
      "text": "Carii ț-vor numelui bine,"
    },
    {
      "index": 56,
      "text": "Că dai bună cuvântare"
    },
    {
      "index": 57,
      "text": "Direptului și spori mare."
    },
    {
      "index": 58,
      "text": "Doamne,-n scut de bună vrere,"
    },
    {
      "index": 59,
      "text": "Ne-ncununi cu mângâiere."
    }
  ]
}